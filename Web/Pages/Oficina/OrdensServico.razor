@page "/oficina"
@inject IOrdemServicoService OrdemService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Application.DTOs.Oficina.OrdemServico
@using Microsoft.AspNetCore.Components.Authorization

@using Microsoft.AspNetCore.Components.Web

<div class="oficina-page">
    <div class="page-header">
        <div>
            <h1 class="page-titulo">Ordens de serviço</h1>
            <p class="page-sub">@ordens.Count ordens no sistema</p>
        </div>
        <button class="btn-nova" @onclick="NovaOrdem">+ Nova OS</button>
    </div>

    <div class="filtros-status">
        @foreach (var s in todosStatus)
        {
            <button class="@FiltroClass(s.valor)"
                    @onclick="() => FiltrarPor(s.valor)">
                <span class="filtro-dot @s.cor"></span>
                @s.label
            </button>
        }
    </div>

    @if (carregando)
    {
        <div class="loading">Carregando ordens...</div>
    }
    else if (!ordensFiltradas.Any())
    {
        <div class="vazio">Nenhuma ordem encontrada.</div>
    }
    else
    {
        <div class="ordens-lista">
            @foreach (var os in ordensFiltradas)
            {
                <div class="os-card" @onclick="() => AbrirDetalhe(os.Id)">
                    <div class="os-numero">@os.NumeroPublico</div>
                    <div class="os-info">
                        <span class="os-descricao">@os.Tipo</span>
                        <span class="os-tipo">@os.Tipo · Prazo: @os.PrazoEstimado.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="os-valor">
                        @os.ValorTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                    </div>
                    <span class="os-status @StatusClass(os.Status)">@os.Status</span>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<OrdemServicoListaDTO> ordens = new();
    private List<OrdemServicoListaDTO> ordensFiltradas = new();
    private string filtroAtivo = "Todos";
    private bool carregando = true;
    private bool ehMecanico = false;
    private Guid mecanicoId;

    private readonly List<(string valor, string label, string cor)> todosStatus = new()
    {
        ("Todos",       "Todas",          "dot-cinza"),
        ("Pendente",    "Pendentes",      "dot-amarelo"),
        ("EmAndamento", "Em andamento",   "dot-azul"),
        ("Finalizada",  "Finalizadas",    "dot-verde"),
        ("Cancelada",   "Canceladas",     "dot-vermelho"),
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        ehMecanico = user.IsInRole("Mecanico");

        var claim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (claim is not null) mecanicoId = Guid.Parse(claim.Value);

        var resultado = await OrdemService.GetAllAsync();
        var todas = resultado.IsSuccess ? resultado.Value?.ToList() ?? new() : new();

        ordens = ehMecanico
            ? todas.Where(o => o.MecanicoId == mecanicoId).ToList()
            : todas;

        AplicarFiltro();
        carregando = false;
    }

    private void FiltrarPor(string status)
    {
        filtroAtivo = status;
        AplicarFiltro();
    }

    private void AplicarFiltro()
    {
        ordensFiltradas = filtroAtivo == "Todos"
            ? ordens.ToList()
            : ordens.Where(o => o.Status == filtroAtivo).ToList();
    }

    private void AbrirDetalhe(Guid id) =>
        Nav.NavigateTo($"/oficina/os/{id}");

    private void NovaOrdem() =>
        Nav.NavigateTo("/oficina/os/nova");

    private string FiltroClass(string status) =>
        status == filtroAtivo ? "filtro-os ativo" : "filtro-os";

    private string StatusClass(string status) => status switch
    {
        "Pendente"    => "status-pendente",
        "EmAndamento" => "status-andamento",
        "Finalizada"  => "status-finalizada",
        "Cancelada"   => "status-cancelada",
        _             => "status-pendente"
    };
}

<style>
    .oficina-page {
        max-width: 960px;
        margin: 0 auto;
        padding: 32px 24px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
    }

    .page-titulo { font-size: 24px; font-weight: 500; margin-bottom: 4px; }
    .page-sub { font-size: 14px; color: #888; }

    .btn-nova {
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-nova:hover { background: #1d4ed8; }

    .filtros-status {
        display: flex;
        gap: 6px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .filtro-os {
        background: #f4f4f4;
        border: 0.5px solid #e0e0e0;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
        color: #555;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .filtro-os.ativo {
        background: #1a1a1a;
        border-color: #1a1a1a;
        color: #fff;
    }

    .filtro-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    .dot-cinza    { background: #aaa; }
    .dot-amarelo  { background: #f59e0b; }
    .dot-azul     { background: #3b82f6; }
    .dot-verde    { background: #22c55e; }
    .dot-vermelho { background: #ef4444; }

    .ordens-lista {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .os-card {
        background: #fff;
        border: 0.5px solid #e0e0e0;
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .os-card:hover { border-color: #3b82f6; }

    .os-numero {
        font-family: monospace;
        font-size: 13px;
        font-weight: 600;
        color: #3b82f6;
        background: #eff6ff;
        padding: 4px 10px;
        border-radius: 6px;
        flex-shrink: 0;
        min-width: 90px;
        text-align: center;
    }

    .os-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex: 1;
    }

    .os-descricao { font-size: 14px; font-weight: 500; }
    .os-tipo { font-size: 12px; color: #888; }

    .os-valor {
        font-size: 15px;
        font-weight: 500;
        color: #1a1a1a;
        flex-shrink: 0;
    }

    .os-status {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 500;
        flex-shrink: 0;
    }

    .status-pendente   { background: #fef9c3; color: #854d0e; }
    .status-andamento  { background: #eff6ff; color: #1d4ed8; }
    .status-finalizada { background: #dcfce7; color: #166534; }
    .status-cancelada  { background: #fff5f5; color: #e02020; }

    .loading, .vazio {
        text-align: center;
        padding: 60px;
        color: #888;
        font-size: 14px;
    }
</style>