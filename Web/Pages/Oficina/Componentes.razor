@page "/oficina/componentes"
@inject IComponenteService ComponenteService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Application.DTOs.Oficina.Componente
@using Microsoft.AspNetCore.Components.Authorization

@using Microsoft.AspNetCore.Components.Web

<div class="comp-page">
    <div class="page-header">
        <div>
            <h1 class="page-titulo">Componentes</h1>
            <p class="page-sub">Estoque de peças da oficina</p>
        </div>
        @if (ehAdmin)
        {
            <button class="btn-novo" @onclick="AbrirModalNovo">+ Novo componente</button>
        }
    </div>

    @if (pecasEstoqueBaixo.Any())
    {
        <div class="alerta-estoque">
            <span class="alerta-icone">⚠</span>
            <span>@pecasEstoqueBaixo.Count peça(s) com estoque abaixo do mínimo</span>
            <button class="alerta-btn" @onclick='() => filtroAtivo = "EstoqueBaixo"'>
                Ver peças
            </button>
        </div>
    }

    <div class="filtros-row">
        <div class="filtros-status">
            <button class="@FiltroClass("Todos")"
                    @onclick='() => FiltrarPor("Todos")'>Todos</button>
            <button class="@FiltroClass("EstoqueBaixo")"
                    @onclick='() => FiltrarPor("EstoqueBaixo")'>Estoque baixo</button>
            @foreach (var s in todosSistemas)
            {
                <button class="@FiltroClass(s)"
                        @onclick="() => FiltrarPor(s)">@s</button>
            }
        </div>
        <input class="busca-input"
               placeholder="Buscar componente..."
               @bind="termoBusca"
               @bind:event="oninput" />
    </div>

    @if (carregando)
    {
        <div class="loading">Carregando componentes...</div>
    }
    else if (!componentesFiltrados.Any())
    {
        <div class="vazio">Nenhum componente encontrado.</div>
    }
    else
    {
        <div class="comp-tabela">
            <div class="tabela-header">
                <span>Nome</span>
                <span>Sistema</span>
                <span>Estoque</span>
                <span>Mínimo</span>
                <span>Valor unit.</span>
                @if (ehAdmin)
                {
                    <span>Ações</span>
                }
            </div>

            @foreach (var c in componentesFiltrados)
            {
                <div class="tabela-row @(c.QuantidadeEstoque <= 0 ? "sem-estoque" : "")">
                    <span class="comp-nome">@c.Nome</span>
                    <span class="comp-sistema">@c.Sistema</span>
                    <span class="comp-qtd @EstoqueClass(c)">
                        @c.QuantidadeEstoque
                    </span>
                    <span class="comp-min">@c.EstoqueMinimo</span>
                    <span class="comp-valor">
                        @c.Valor.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                    </span>
                    @if (ehAdmin)
                    {
                        <div class="comp-acoes">
                            <button class="btn-mini verde"
                                    @onclick="() => AbrirModalEntrada(c)">
                                + Entrada
                            </button>
                            <button class="btn-mini"
                                    @onclick="() => AbrirModalEditar(c)">
                                Editar
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@if (modalNovoVisivel)
{
    <div class="modal-overlay" @onclick="() => modalNovoVisivel = false">
        <div class="modal-form" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-titulo">
                    @(modoEditar ? "Editar componente" : "Novo componente")
                </span>
                <button class="modal-fechar"
                        @onclick="() => modalNovoVisivel = false">×</button>
            </div>

            <div class="form-grid">
                <div class="form-campo span-2">
                    <label class="campo-label">Nome *</label>
                    <input class="campo-input" @bind="formComp.Nome" />
                </div>
                <div class="form-campo span-2">
                    <label class="campo-label">Modelo</label>
                    <input class="campo-input" @bind="formComp.Modelo" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Sistema</label>
                    <select class="campo-input" @bind="formComp.Sistema">
                        @foreach (var s in todosSistemas)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="form-campo">
                    <label class="campo-label">Valor (R$)</label>
                    <input type="number" class="campo-input" @bind="formComp.Valor" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Quantidade inicial</label>
                    <input type="number" class="campo-input"
                           @bind="formComp.QuantidadeEstoque"
                           disabled="@modoEditar" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Estoque mínimo</label>
                    <input type="number" class="campo-input"
                           @bind="formComp.EstoqueMinimo" />
                </div>
            </div>

            @if (erroForm is not null)
            {
                <div class="erro-banner">@erroForm</div>
            }

            <div class="modal-acoes">
                <button class="btn-cancelar"
                        @onclick="() => modalNovoVisivel = false">Cancelar</button>
                <button class="btn-confirmar"
                        @onclick="SalvarComponente"
                        disabled="@salvando">
                    @(salvando ? "Salvando..." : (modoEditar ? "Salvar" : "Cadastrar"))
                </button>
            </div>
        </div>
    </div>
}

@if (modalEntradaVisivel)
{
    <div class="modal-overlay" @onclick="() => modalEntradaVisivel = false">
        <div class="modal-form pequeno" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-titulo">Entrada de estoque</span>
                <button class="modal-fechar"
                        @onclick="() => modalEntradaVisivel = false">×</button>
            </div>
            <p class="modal-sub">@componenteSelecionado?.Nome</p>
            <p class="modal-sub">
                Estoque atual: @componenteSelecionado?.QuantidadeEstoque unidades
            </p>

            <div class="form-campo" style="margin-top: 16px;">
                <label class="campo-label">Quantidade a adicionar</label>
                <input type="number" class="campo-input"
                       @bind="quantidadeEntrada"
                       min="1" />
            </div>

            @if (erroForm is not null)
            {
                <div class="erro-banner">@erroForm</div>
            }

            <div class="modal-acoes">
                <button class="btn-cancelar"
                        @onclick="() => modalEntradaVisivel = false">Cancelar</button>
                <button class="btn-confirmar verde"
                        @onclick="ConfirmarEntrada"
                        disabled="@salvando">
                    @(salvando ? "Salvando..." : "Confirmar entrada")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ComponenteDTO> componentes = new();
    private List<ComponenteDTO> componentesFiltrados = new();
    private List<ComponenteListaDTO> pecasEstoqueBaixo = new();
    private string filtroAtivo = "Todos";
    private string termoBusca = string.Empty;
    private bool carregando = true;
    private bool ehAdmin = false;
    private bool modalNovoVisivel = false;
    private bool modalEntradaVisivel = false;
    private bool modoEditar = false;
    private bool salvando = false;
    private string? erroForm;
    private ComponenteDTO? componenteSelecionado;
    private int quantidadeEntrada = 1;

    private CriarComponenteDTO formComp = new();
    private AtualizarComponenteDTO formEditar = new();

    private readonly List<string> todosSistemas = new()
    {
        "Motor", "Freios", "Suspensao", "Eletrica",
        "Transmissao", "Arrefecimento", "Escapamento", "Outro"
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        ehAdmin = state.User.IsInRole("Admin");

        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true;

        var resultado = await ComponenteService.GetAllAsync();
        if (resultado.IsSuccess)
        {
            componentes = resultado.Value?
                .Select(c => new ComponenteDTO
                {
                    Id = c.Id,
                    Nome = c.Nome,
                    Sistema = c.Sistema,
                    QuantidadeEstoque = c.QuantidadeEstoque,
                    Valor = c.Valor,
                    Modelo = c.Modelo
                }).ToList() ?? new();
        }

        var baixo = await ComponenteService.ObterComEstoqueBaixoAsync();
        pecasEstoqueBaixo = baixo.IsSuccess
            ? baixo.Value?.ToList() ?? new()
            : new();

        AplicarFiltro();
        carregando = false;
    }

    private void FiltrarPor(string filtro)
    {
        filtroAtivo = filtro;
        AplicarFiltro();
    }

    private void AplicarFiltro()
    {
        var base_ = filtroAtivo switch
        {
            "EstoqueBaixo" => componentes
                .Where(c => c.QuantidadeEstoque <= c.EstoqueMinimo).ToList(),
            "Todos" => componentes.ToList(),
            _ => componentes.Where(c => c.Sistema == filtroAtivo).ToList()
        };

        componentesFiltrados = string.IsNullOrWhiteSpace(termoBusca)
            ? base_
            : base_.Where(c => c.Nome.Contains(
                termoBusca, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void AbrirModalNovo()
    {
        modoEditar = false;
        formComp = new CriarComponenteDTO { Sistema = "Motor" };
        erroForm = null;
        modalNovoVisivel = true;
    }

    private void AbrirModalEditar(ComponenteDTO c)
    {
        modoEditar = true;
        formEditar = new AtualizarComponenteDTO
        {
            Id = c.Id,
            Valor = c.Valor,
            QuantidadeEstoque = c.QuantidadeEstoque,
            EstoqueMinimo = c.EstoqueMinimo
        };
        formComp = new CriarComponenteDTO
        {
            Nome = c.Nome,
            Modelo = c.Modelo,
            Sistema = c.Sistema,
            Valor = c.Valor,
            QuantidadeEstoque = c.QuantidadeEstoque,
            EstoqueMinimo = c.EstoqueMinimo
        };
        erroForm = null;
        modalNovoVisivel = true;
    }

    private void AbrirModalEntrada(ComponenteDTO c)
    {
        componenteSelecionado = c;
        quantidadeEntrada = 1;
        erroForm = null;
        modalEntradaVisivel = true;
    }

    private async Task SalvarComponente()
    {
        salvando = true;
        erroForm = null;

        try
        {
            if (modoEditar)
            {
                formEditar.Valor = formComp.Valor;
                formEditar.EstoqueMinimo = formComp.EstoqueMinimo;
                var r = await ComponenteService.UpdateAsync(formEditar);
                if (r.IsSuccess) { modalNovoVisivel = false; await CarregarDados(); }
                else erroForm = r.Error;
            }
            else
            {
                var r = await ComponenteService.AddAsync(formComp);
                if (r.IsSuccess) { modalNovoVisivel = false; await CarregarDados(); }
                else erroForm = r.Error;
            }
        }
        catch { erroForm = "Erro ao salvar."; }
        finally { salvando = false; }
    }

    private async Task ConfirmarEntrada()
    {
        if (quantidadeEntrada <= 0 || componenteSelecionado is null) return;

        salvando = true;
        erroForm = null;

        var resultado = await ComponenteService.EntradaEstoqueAsync(
            componenteSelecionado.Id, quantidadeEntrada);

        if (resultado.IsSuccess)
        {
            modalEntradaVisivel = false;
            await CarregarDados();
        }
        else
        {
            erroForm = resultado.Error;
        }

        salvando = false;
    }

    private string FiltroClass(string f) =>
        f == filtroAtivo ? "filtro-os ativo" : "filtro-os";

    private string EstoqueClass(ComponenteDTO c)
    {
        if (c.QuantidadeEstoque <= 0) return "qtd-zero";
        if (c.QuantidadeEstoque <= c.EstoqueMinimo) return "qtd-baixo";
        return "qtd-ok";
    }
}

