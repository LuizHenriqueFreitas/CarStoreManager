@page "/login"

@namespace CarStoreManager.Web.Components.Pages

@inject IAuthService AuthService
@inject NavigationManager Nav
@inject JwtAuthStateProvider AuthProvider
@using CarStoreManager.Application.DTOs.Auth
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Web.Components.Shared
@using CarStoreManager.Web.Components.Shared.Auth
@using Microsoft.AspNetCore.Components.Web

<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <span class="logo-texto">AUTO</span><span class="logo-destaque">STORE</span>
        </div>
        <p class="login-sub">Sistema de gestão interno</p>

        <div class="login-form">
            <div class="campo">
                <label class="campo-label">E-mail</label>
                <input class="campo-input @(erro is not null ? "campo-erro" : "")"
                       type="email"
                       placeholder="seu@email.com"
                       @bind="email"
                       @onkeydown="TeclaPressionada" />
            </div>

            <div class="campo">
                <label class="campo-label">Senha</label>
                <input class="campo-input @(erro is not null ? "campo-erro" : "")"
                       type="password"
                       placeholder="••••••••"
                       @bind="senha"
                       @onkeydown="TeclaPressionada" />
            </div>

            @if (erro is not null)
            {
                <div class="erro-banner">@erro</div>
            }

            <button class="btn-entrar" @onclick="Entrar" disabled="@carregando">
                @(carregando ? "Entrando..." : "Entrar")
            </button>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string senha = string.Empty;
    private string? erro;
    private bool carregando = false;

    protected override async Task OnInitializedAsync()
{
    // Se a URL contiver logout=true, não redireciona automaticamente
    var uri = new Uri(Nav.Uri);
    var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
    if (query["logout"] == "true")
        return; // Não faz nada, permite a tela de login

    var state = await AuthProvider.GetAuthenticationStateAsync();
    if (state.User.Identity?.IsAuthenticated ?? false)
        Nav.NavigateTo("/");
}

    private async Task Entrar()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(senha))
        {
            erro = "Preencha e-mail e senha.";
            return;
        }

        carregando = true;
        erro = null;

        try
        {
            var resultado = await AuthService.LoginAsync(new LoginDTO
            {
                Email = email,
                Senha = senha
            });

            if (!resultado.IsSuccess)
            {
                erro = resultado.Error ?? "E-mail ou senha inválidos.";
                return;
            }

            await AuthProvider.LoginAsync(resultado.Value!.Token);
            Nav.NavigateTo("/");
        }
        catch
        {
            erro = "Erro de conexão. Tente novamente.";
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task TeclaPressionada(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Entrar();
    }
}

<style>
    .login-page {
        min-height: 100vh;
        background: #111;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        background: #1a1a1a;
        border: 0.5px solid #333;
        border-radius: 16px;
        padding: 40px;
        width: 100%;
        max-width: 380px;
        text-align: center;
    }

    .login-logo {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 2px;
        margin-bottom: 6px;
    }

    .logo-texto { color: #fff; }
    .logo-destaque { color: #e02020; }

    .login-sub {
        color: #666;
        font-size: 13px;
        margin-bottom: 32px;
    }

    .login-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
        text-align: left;
    }

    .campo { display: flex; flex-direction: column; gap: 6px; }

    .campo-label {
        font-size: 12px;
        color: #888;
        font-weight: 500;
    }

    .campo-input {
        background: #222;
        border: 0.5px solid #444;
        border-radius: 8px;
        padding: 11px 14px;
        font-size: 14px;
        color: #fff;
        outline: none;
        transition: border-color 0.2s;
        width: 100%;
    }

    .campo-input::placeholder { color: #555; }
    .campo-input:focus { border-color: #e02020; }
    .campo-erro { border-color: #e02020 !important; }

    .erro-banner {
        background: rgba(224, 32, 32, 0.1);
        border: 0.5px solid rgba(224, 32, 32, 0.3);
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #e02020;
        text-align: center;
    }

    .btn-entrar {
        background: #e02020;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 13px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        width: 100%;
        margin-top: 8px;
        transition: background 0.2s;
    }

    .btn-entrar:hover:not(:disabled) { background: #c01818; }
    .btn-entrar:disabled { opacity: 0.6; cursor: not-allowed; }
</style>