@page "/concessionaria/veiculo/novo"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@namespace CarStoreManager.Web.Components.Pages

@inject IVeiculoVendaService VeiculoService
@inject IFotoService FotoService
@inject NavigationManager Nav
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthState

@using CarStoreManager.Application.Common
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Application.DTOs.Concessionaria.VeiculoVenda
@using CarStoreManager.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms

@using Microsoft.AspNetCore.Components.Web

<div class="form-page">
    <div class="page-header">
        <button class="btn-voltar" @onclick='() => Nav.NavigateTo("/concessionaria")'>
            ← Voltar
        </button>
        <h1 class="page-titulo">Cadastrar veículo</h1>
    </div>

    <div class="form-card">
        <h2 class="secao-titulo">Identificação do veículo</h2>
        <div class="form-grid">
            <div class="form-campo">
                <label class="campo-label">Marca *</label>
                <input class="campo-input" @bind="form.Marca" placeholder="Ex: Honda" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Modelo *</label>
                <input class="campo-input" @bind="form.Modelo" placeholder="Ex: Civic" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Ano *</label>
                <input type="number" class="campo-input" @bind="form.Ano" placeholder="2024" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Cor *</label>
                <input class="campo-input" @bind="form.Cor" placeholder="Ex: Prata" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Placa *</label>
                <input class="campo-input" @bind="form.Placa" placeholder="ABC1D23 ou ABC1234" />
            </div>
            <div class="form-campo">
                <label class="campo-label">RENAVAM *</label>
                <input class="campo-input" @bind="form.Renavam" placeholder="9 a 11 dígitos com DV" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Motorização *</label>
                <input class="campo-input" @bind="form.Motorizacao" placeholder="Ex: 1.5 Turbo" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Quilometragem *</label>
                <input type="number" class="campo-input" @bind="form.Quilometragem" placeholder="0" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Valor de venda (R$) *</label>
                <input type="number" step="0.01" class="campo-input" @bind="form.Valor" placeholder="0,00" />
            </div>
            <div class="form-campo">
                <label class="campo-label">Ano do último IPVA pago</label>
                <input type="number" class="campo-input" @bind="form.AnoUltimoIpvaPago"
                       placeholder="(opcional)" />
            </div>
        </div>
    </div>

    <div class="form-card">
        <h2 class="secao-titulo">Características</h2>
        <div class="form-grid">
            <div class="form-campo">
                <label class="campo-label">Câmbio</label>
                <select class="campo-input" @bind="form.Cambio">
                    <option value="Manual">Manual</option>
                    <option value="Automatico">Automático</option>
                </select>
            </div>
            <div class="form-campo">
                <label class="campo-label">Combustível</label>
                <select class="campo-input" @bind="form.Combustivel">
                    <option value="Flex">Flex</option>
                    <option value="Gasolina">Gasolina</option>
                    <option value="Alcool">Álcool</option>
                    <option value="Diesel">Diesel</option>
                    <option value="Eletrico">Elétrico</option>
                    <option value="Hibrido">Híbrido</option>
                </select>
            </div>
        </div>
    </div>

    <div class="form-card">
        <h2 class="secao-titulo">Acessórios</h2>
        <div class="acessorios-grid">
            @foreach (var acc in todosAcessorios)
            {
                <label class="acc-check">
                    <input type="checkbox"
                           checked="@acessoriosSelecionados.Contains(acc.valor)"
                           @onchange="() => ToggleAcessorio(acc.valor)" />
                    <span>@acc.label</span>
                </label>
            }
        </div>
    </div>

    <div class="form-card">
        <h2 class="secao-titulo">Termo de entrega preliminar</h2>
        <p class="secao-sub">
            Esboce aqui o texto do termo de entrega — quando uma proposta for gerada,
            esse texto será a base do termo final. O veículo nasce com status
            <strong>Em preparação</strong> e só vai para venda depois que você liberar.
        </p>
        <textarea class="campo-input" rows="8"
                  @bind="form.TextoTermoPreliminar"
                  placeholder="Ex: A concessionária declara que o veículo X foi entregue em perfeitas condições mecânicas, com documentação regularizada..."></textarea>
    </div>

    <div class="form-card">
        <h2 class="secao-titulo">Fotos do anúncio</h2>
        <p class="secao-sub">JPEG ou PNG, até 5MB cada. Você poderá reordenar depois.</p>

        <InputFile OnChange="OnFotosSelecionadas" multiple
                   accept="image/jpeg,image/png" class="file-input" />

        @if (previewsNovasFotos.Any())
        {
            <div class="previews">
                @for (int i = 0; i < previewsNovasFotos.Count; i++)
                {
                    var idx = i;
                    <div class="preview-item">
                        <img src="@previewsNovasFotos[idx]" alt="prévia" />
                        <button type="button" class="preview-remove"
                                @onclick="() => RemoverFotoSelecionada(idx)">×</button>
                    </div>
                }
            </div>
        }
    </div>

    @if (erro is not null)
    {
        <div class="erro-banner">@erro</div>
    }

    @if (sucesso)
    {
        <div class="sucesso-banner">Veículo cadastrado com sucesso!</div>
    }

    <div class="form-acoes">
        <button class="btn-cancelar"
                @onclick='() => Nav.NavigateTo("/concessionaria")'>
            Cancelar
        </button>
        <button class="btn-salvar" @onclick="IniciarSalvamento" disabled="@salvando">
            @(salvando ? "Salvando..." : "Cadastrar veículo")
        </button>
    </div>
</div>

<ConfirmacaoSenhaModal Visivel="modalSenhaVisivel"
                       Titulo="Confirmar cadastro do veículo"
                       Descricao="Esta ação registrará um novo veículo no estoque da concessionária. Digite sua senha para confirmar."
                       TextoBotao="Cadastrar veículo"
                       OnConfirmar="OnSenhaConfirmada"
                       OnCancelar="() => modalSenhaVisivel = false"
                       @ref="modalSenhaRef" />

@code {
    private CriarVeiculoVendaDTO form = new()
    {
        Cambio = "Manual",
        Combustivel = "Flex",
        Acessorios = new List<string>()
    };

    private List<string> acessoriosSelecionados = new();
    // Carrega o byte[] na memória já no momento da seleção, porque o stream
    // de IBrowserFile só é válido enquanto o handler está executando.
    private record FotoEmMemoria(string Nome, string ContentType, byte[] Conteudo);
    private List<FotoEmMemoria> arquivosSelecionados = new();
    private List<string> previewsNovasFotos = new();
    private bool salvando = false;
    private bool sucesso = false;
    private string? erro;

    private readonly List<(string valor, string label)> todosAcessorios = new()
    {
        ("ArCondicionado", "Ar-condicionado"),
        ("VidrosEletricos", "Vidros elétricos"),
        ("DirecaoHidraulica", "Direção hidráulica"),
        ("TetoSolar", "Teto solar"),
        ("BancoCouro", "Banco em couro"),
        ("CameraRe", "Câmera de ré"),
        ("SensorEstacionamento", "Sensor de estacionamento"),
        ("CentralMultimidia", "Central multimídia"),
        ("Alarme", "Alarme"),
        ("TravasEletrica", "Travas elétricas"),
        ("RodaLiga", "Rodas de liga"),
        ("Bluetooth", "Bluetooth")
    };

    private void ToggleAcessorio(string valor)
    {
        if (acessoriosSelecionados.Contains(valor))
            acessoriosSelecionados.Remove(valor);
        else
            acessoriosSelecionados.Add(valor);
    }

    private async Task OnFotosSelecionadas(InputFileChangeEventArgs e)
    {
        const long max = 5 * 1024 * 1024;
        foreach (var file in e.GetMultipleFiles(20))
        {
            if (file.Size > max) continue;
            if (file.ContentType != "image/jpeg" && file.ContentType != "image/png") continue;

            // Lê o conteúdo NESTE handler (única janela em que o stream é válido).
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: max).CopyToAsync(ms);
            var bytes = ms.ToArray();

            arquivosSelecionados.Add(new FotoEmMemoria(file.Name, file.ContentType, bytes));

            var base64 = Convert.ToBase64String(bytes);
            previewsNovasFotos.Add($"data:{file.ContentType};base64,{base64}");
        }

        StateHasChanged();
    }

    private void RemoverFotoSelecionada(int indice)
    {
        if (indice < 0 || indice >= arquivosSelecionados.Count) return;
        arquivosSelecionados.RemoveAt(indice);
        previewsNovasFotos.RemoveAt(indice);
    }

    private bool modalSenhaVisivel;
    private ConfirmacaoSenhaModal? modalSenhaRef;

    private void IniciarSalvamento()
    {
        // Pré-validação: só abre o modal de senha se o formulário já está OK.
        if (string.IsNullOrWhiteSpace(form.Marca) ||
            string.IsNullOrWhiteSpace(form.Modelo) ||
            string.IsNullOrWhiteSpace(form.Placa) ||
            string.IsNullOrWhiteSpace(form.Renavam))
        {
            erro = "Preencha todos os campos obrigatórios (incluindo RENAVAM).";
            return;
        }
        erro = null;
        modalSenhaVisivel = true;
    }

    private async Task OnSenhaConfirmada(string senha)
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var idClaim = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (idClaim is null || !Guid.TryParse(idClaim.Value, out var usuarioId))
        {
            modalSenhaRef?.MostrarErro();
            return;
        }
        var verif = await AuthService.VerificarSenhaAsync(usuarioId, senha);
        if (!verif.IsSuccess)
        {
            modalSenhaRef?.MostrarErro();
            return;
        }
        await ExecutarSalvamento();
    }

    private async Task ExecutarSalvamento()
    {
        modalSenhaVisivel = false;

        salvando = true;
        erro = null;
        sucesso = false;
        form.Acessorios = new List<string>(acessoriosSelecionados);

        try
        {
            var resultado = await VeiculoService.AddAsync(form);
            if (!resultado.IsSuccess)
            {
                erro = resultado.Error;
                return;
            }

            var veiculoId = resultado.Value;

            // Sobe as fotos selecionadas, se houver — agora a partir do byte[]
            // já carregado, então independe do ciclo de vida do IBrowserFile.
            if (arquivosSelecionados.Count > 0)
            {
                var arquivos = arquivosSelecionados
                    .Select(f => new ArquivoUpload(
                        f.Nome, f.Conteudo.Length, f.ContentType,
                        () => new MemoryStream(f.Conteudo)))
                    .ToList();

                var rUpload = await FotoService.UploadFotosAsync("VeiculoVenda", veiculoId, arquivos);
                if (!rUpload.IsSuccess)
                {
                    erro = $"Veículo cadastrado, mas falhou o upload de fotos: {rUpload.Error}";
                    Nav.NavigateTo($"/concessionaria/veiculo/{veiculoId}");
                    return;
                }
            }

            sucesso = true;
            await Task.Delay(900);
            Nav.NavigateTo($"/concessionaria/veiculo/{veiculoId}");
        }
        catch (Exception ex)
        {
            erro = $"Erro ao cadastrar veículo: {ex.Message}";
        }
        finally { salvando = false; }
    }
}

<style>
    .form-page {
        max-width: 800px;
        margin: 0 auto;
        padding: 24px;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .btn-voltar {
        background: none;
        border: none;
        color: #888;
        font-size: 14px;
        cursor: pointer;
        padding: 0;
    }

    .btn-voltar:hover { color: #1a1a1a; }

    .page-titulo { font-size: 22px; font-weight: 500; }

    .form-card {
        background: #fff;
        border: 0.5px solid #e0e0e0;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
    }

    .secao-titulo {
        font-size: 14px;
        font-weight: 500;
        color: #1a1a1a;
        margin-bottom: 6px;
        padding-bottom: 10px;
        border-bottom: 0.5px solid #eee;
    }

    .secao-sub { font-size: 12px; color: #888; margin-bottom: 12px; }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .form-campo { display: flex; flex-direction: column; gap: 6px; }

    .campo-label { font-size: 12px; color: #555; font-weight: 500; }

    .campo-input {
        border: 0.5px solid #ccc;
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 14px;
        outline: none;
        width: 100%;
        transition: border-color 0.2s;
    }

    .campo-input:focus { border-color: #e02020; }

    .acessorios-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .acc-check {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #444;
        cursor: pointer;
    }

    .acc-check input { cursor: pointer; accent-color: #e02020; }

    .file-input {
        display: block;
        margin-bottom: 12px;
        font-size: 13px;
    }

    .previews {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 8px;
    }

    .preview-item {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 4/3;
        background: #f4f4f4;
    }

    .preview-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .preview-remove {
        position: absolute;
        top: 4px;
        right: 4px;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: rgba(0,0,0,0.6);
        color: #fff;
        border: none;
        cursor: pointer;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .erro-banner {
        background: #fff5f5;
        border: 0.5px solid #fca5a5;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 13px;
        color: #e02020;
        margin-bottom: 16px;
    }

    .sucesso-banner {
        background: #f0fdf4;
        border: 0.5px solid #86efac;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 13px;
        color: #166534;
        margin-bottom: 16px;
    }

    .form-acoes {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 8px;
    }

    .btn-cancelar {
        background: #fff;
        border: 0.5px solid #ccc;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 14px;
        cursor: pointer;
        color: #444;
    }

    .btn-salvar {
        background: #e02020;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 24px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-salvar:hover:not(:disabled) { background: #c01818; }
    .btn-salvar:disabled { opacity: 0.6; cursor: not-allowed; }
</style>
