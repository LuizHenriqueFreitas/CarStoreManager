@page "/concessionaria/veiculo/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Vendedor")]

@namespace CarStoreManager.Web.Components.Pages

@inject IVeiculoVendaService VeiculoService
@inject IFotoService FotoService
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@using CarStoreManager.Application.Common
@using CarStoreManager.Application.Interfaces
@inject NavigationManager Nav
@using CarStoreManager.Application.DTOs.Concessionaria.VeiculoVenda
@using CarStoreManager.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.IO

@if (carregando)
{
    <div class="loading">Carregando...</div>
}
else if (veiculo is null)
{
    <div class="loading">Veículo não encontrado.</div>
}
else
{
    <div class="galeria-wrapper">
        <div class="galeria-principal">
            @if (veiculo.Fotos.Any())
            {
                @* Mostra a foto principal com object-fit contain (sem esticar/cortar)
                   e prévias parciais das fotos vizinhas nas margens. *@
                <button class="galeria-arr left" @onclick="FotoAnterior"
                        style="@(veiculo.Fotos.Count > 1 ? "" : "display:none")">‹</button>

                @if (veiculo.Fotos.Count > 1)
                {
                    var idxAnt = (fotoAtiva - 1 + veiculo.Fotos.Count) % veiculo.Fotos.Count;
                    <div class="galeria-vizinha esquerda" @onclick="FotoAnterior">
                        <img src="@veiculo.Fotos[idxAnt]" alt="" />
                    </div>
                }

                <div class="galeria-foto" @onclick="() => AbrirFullscreen(fotoAtiva)">
                    <img src="@veiculo.Fotos[fotoAtiva]" alt="Foto do veículo" />
                    <span class="galeria-zoom">🔍</span>
                </div>

                @if (veiculo.Fotos.Count > 1)
                {
                    var idxProx = (fotoAtiva + 1) % veiculo.Fotos.Count;
                    <div class="galeria-vizinha direita" @onclick="ProximaFoto">
                        <img src="@veiculo.Fotos[idxProx]" alt="" />
                    </div>
                }

                <button class="galeria-arr right" @onclick="ProximaFoto"
                        style="@(veiculo.Fotos.Count > 1 ? "" : "display:none")">›</button>
            }
            else
            {
                <div class="galeria-vazia">Sem fotos cadastradas</div>
            }
        </div>

        @if (veiculo.Fotos.Count > 1)
        {
            <div class="galeria-dots">
                @for (int i = 0; i < veiculo.Fotos.Count; i++)
                {
                    var idx = i;
                    <span class="@(i == fotoAtiva ? "dot ativo" : "dot")"
                          @onclick="() => fotoAtiva = idx"></span>
                }
            </div>
        }
    </div>

    @if (fotoFullscreenIdx is not null)
    {
        <div class="fs-overlay" @onclick="FecharFullscreen">
            <button class="fs-fechar" @onclick="FecharFullscreen" @onclick:stopPropagation="true">✕</button>
            @if (veiculo.Fotos.Count > 1)
            {
                <button class="fs-arr left" @onclick:stopPropagation="true" @onclick="FsAnterior">‹</button>
                <button class="fs-arr right" @onclick:stopPropagation="true" @onclick="FsProxima">›</button>
            }
            <img src="@veiculo.Fotos[fotoFullscreenIdx.Value]" class="fs-img" @onclick:stopPropagation="true" alt="Foto ampliada" />
        </div>
    }

    <div class="detalhe-content">
        <div class="detalhe-main">
            <div class="detalhe-header">
                <div>
                    <h1 class="detalhe-titulo">@veiculo.Marca @veiculo.Modelo</h1>
                    <p class="detalhe-sub">@veiculo.Ano · @veiculo.Combustivel · @veiculo.Cambio · @veiculo.Motorizacao</p>
                </div>
                <span class="badge @BadgeClass">@veiculo.Disponibilidade</span>
            </div>

            <div class="detalhe-section">
                <h2 class="section-titulo">Especificações</h2>
                <div class="specs-grid">
                    <div class="spec"><span class="spec-label">Ano</span><span class="spec-val">@veiculo.Ano</span></div>
                    <div class="spec"><span class="spec-label">Quilometragem</span><span class="spec-val">@veiculo.Quilometragem.ToString("N0") km</span></div>
                    <div class="spec"><span class="spec-label">Cor</span><span class="spec-val">@veiculo.Cor</span></div>
                    <div class="spec"><span class="spec-label">Combustível</span><span class="spec-val">@veiculo.Combustivel</span></div>
                    <div class="spec"><span class="spec-label">Câmbio</span><span class="spec-val">@veiculo.Cambio</span></div>
                    <div class="spec"><span class="spec-label">Motorização</span><span class="spec-val">@veiculo.Motorizacao</span></div>
                    <div class="spec"><span class="spec-label">Placa</span><span class="spec-val">@veiculo.Placa</span></div>
                </div>
            </div>

            @if (veiculo.Acessorios.Any())
            {
                <div class="detalhe-section">
                    <h2 class="section-titulo">Acessórios</h2>
                    <div class="acc-lista">
                        @foreach (var acc in veiculo.Acessorios)
                        {
                            <span class="acc-tag">
                                <span class="acc-dot"></span>
                                @acc
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="detalhe-sidebar">
            <div class="preco-card">
                <span class="preco-label">Valor</span>
                <span class="preco-val">
                    @veiculo.Valor.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                </span>

                @if (veiculo.Disponibilidade == "Disponivel")
                {
                    <button class="btn-primary" @onclick="GerarProposta">
                        Gerar proposta de venda
                    </button>
                }
                else if (veiculo.Disponibilidade == "EmPreparacao")
                {
                    <div class="preparacao-aviso">
                        ⚙ Veículo em preparação (lavagem / ajustes / documentação)
                    </div>
                    <AuthorizeView Roles="Admin" Context="ctxLib">
                        <Authorized>
                            <button class="btn-primary" @onclick="LiberarParaVenda">
                                ✓ Liberar para venda
                            </button>
                        </Authorized>
                    </AuthorizeView>
                }

                @if (veiculo.Disponibilidade == "Disponivel")
                {
                    <AuthorizeView Roles="Admin" Context="ctxVolta">
                        <Authorized>
                            <button class="btn-secondary" @onclick="VoltarParaPreparacao">
                                ⚙ Voltar para preparação
                            </button>
                        </Authorized>
                    </AuthorizeView>
                }

                <button class="btn-secondary" @onclick="AbrirModalEdicao">
                    Editar veículo
                </button>

                <button class="btn-excluir" @onclick="AbrirModalExclusao">
                    Excluir veículo
                </button>

                <button class="btn-voltar" @onclick='() => Nav.NavigateTo("/concessionaria")'>
                    ← Voltar ao estoque
                </button>
            </div>
        </div>
    </div>

    <ConfirmacaoSenhaModal
        Visivel="modalSalvarEdicaoVisivel"
        Titulo="Confirmar alterações"
        Descricao="@($"Salvar alterações em {veiculo.Marca} {veiculo.Modelo}? Confirme com sua senha.")"
        TextoBotao="Salvar alterações"
        OnConfirmar="ConfirmarSalvarEdicao"
        OnCancelar="() => modalSalvarEdicaoVisivel = false"
        @ref="modalSalvarEdicaoRef" />

    <ConfirmacaoSenhaModal
        Visivel="modalExclusaoVisivel"
        Titulo="Excluir veículo"
        Descricao="@($"Tem certeza que deseja excluir {veiculo.Marca} {veiculo.Modelo}? Esta ação não pode ser desfeita.")"
        TextoBotao="Excluir permanentemente"
        Destrutivo="true"
        ApenasAdmin="true"
        OnConfirmar="ConfirmarExclusao"
        OnCancelar="() => modalExclusaoVisivel = false"
        @ref="modalExclusaoRef" />

    @if (modalFormEdicaoVisivel)
    {
        <div class="modal-overlay" @onclick="() => modalFormEdicaoVisivel = false">
            <div class="modal-form" @onclick:stopPropagation>
                <div class="modal-header">
                    <span class="modal-titulo">Editar veículo</span>
                    <button class="modal-fechar" @onclick="() => modalFormEdicaoVisivel = false">×</button>
                </div>

                <div class="form-grid">
                    <div class="form-campo">
                        <label class="campo-label">Valor (R$)</label>
                        <input type="number" class="campo-input" @bind="formEdicao.Valor" />
                    </div>
                    <div class="form-campo">
                        <label class="campo-label">Disponibilidade</label>
                        <select class="campo-input" @bind="formEdicao.Disponibilidade">
                            <option value="EmPreparacao">Em preparação</option>
                            <option value="Disponivel">Disponível</option>
                            <option value="Reservado">Reservado</option>
                            <option value="Vendido">Vendido</option>
                        </select>
                    </div>
                </div>

                <div class="form-secao">
                    <label class="campo-label">Termo de entrega preliminar</label>
                    <p class="secao-sub" style="font-size:.85em; color:#666; margin:4px 0 6px;">
                        Será usado como base do termo final quando a proposta for gerada.
                    </p>
                    <textarea class="campo-input" rows="6"
                              @bind="formEdicao.TextoTermoPreliminar"
                              placeholder="Texto do termo de entrega..."></textarea>
                </div>

                <!-- SEÇÃO DE GERENCIAMENTO DE FOTOS -->
                <div class="form-secao">
                    <h3 class="secao-titulo">Fotos do veículo</h3>

                    @if (fotosEditaveis.Any())
                    {
                        <div class="fotos-lista">
                            @for (int i = 0; i < fotosEditaveis.Count; i++)
                            {
                                var foto = fotosEditaveis[i];
                                var idx = i;
                                <div class="foto-item">
                                    <img src="@foto.Url" class="foto-thumb" />
                                    <div class="foto-acoes">
                                        <button type="button" class="btn-ordem" @onclick="() => MoverFotoParaCima(idx)" disabled="@(idx == 0)">▲</button>
                                        <button type="button" class="btn-ordem" @onclick="() => MoverFotoParaBaixo(idx)" disabled="@(idx == fotosEditaveis.Count - 1)">▼</button>
                                        <button type="button" class="btn-remover-foto" @onclick="() => RemoverFoto(idx)">🗑️</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="sem-fotos-msg">Nenhuma foto cadastrada.</div>
                    }

                    <div class="upload-area">
                        <label class="upload-label">
                            <InputFile OnChange="OnArquivoSelecionado" multiple accept="image/jpeg,image/png" />
                            <span class="upload-icone">📸</span> Selecionar novas fotos
                        </label>
                        @if (arquivosSelecionados.Any())
                        {
                            <div class="preview-novas">
                                @foreach (var preview in previewsNovasFotos)
                                {
                                    <img src="@preview" class="preview-thumb" />
                                }
                                <button class="btn-upload" @onclick="UploadNovasFotos" disabled="@uploading">
                                    @(uploading ? "Enviando..." : $"Enviar {arquivosSelecionados.Count} foto(s)")
                                </button>
                                <button class="btn-cancelar-upload" @onclick="CancelarUpload">Cancelar</button>
                            </div>
                        }
                        @if (erroUpload != null)
                        {
                            <div class="erro-upload">@erroUpload</div>
                        }
                    </div>
                </div>

                @if (erroEdicao is not null)
                {
                    <div class="erro-banner">@erroEdicao</div>
                }

                <div class="modal-acoes">
                    <button class="btn-cancelar"
                            @onclick="() => modalFormEdicaoVisivel = false">
                        Cancelar
                    </button>
                    <button class="btn-confirmar"
                            @onclick="SalvarEdicao"
                            disabled="@salvando">
                        @(salvando ? "Salvando..." : "Salvar alterações")
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private VeiculoVendaDTO? veiculo;
    private bool carregando = true;
    private int fotoAtiva = 0;

    private bool modalExclusaoVisivel = false;
    private bool modalFormEdicaoVisivel = false;
    private bool modalSalvarEdicaoVisivel = false;
    private bool salvando = false;
    private string? erroEdicao;

    private ConfirmacaoSenhaModal? modalSalvarEdicaoRef;
    private ConfirmacaoSenhaModal? modalExclusaoRef;

    private AtualizarVeiculoVendaDTO formEdicao = new();

    private Guid UsuarioAtualId;

    // Propriedades para gerenciamento de fotos
    private List<FotoVeiculoDTO> fotosEditaveis = new();
    private record FotoEmMemoria(string Nome, string ContentType, byte[] Conteudo);
    private List<FotoEmMemoria> arquivosSelecionados = new();
    private List<string> previewsNovasFotos = new();
    private bool uploading = false;
    private string? erroUpload = null;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier);

        if (claim is not null)
            UsuarioAtualId = Guid.Parse(claim.Value);

        await CarregarVeiculo();
    }

    private async Task CarregarVeiculo()
    {
        try
        {
            var resultado = await VeiculoService.GetByIdAsync(Id);
            veiculo = resultado.IsSuccess ? resultado.Value : null;
            if (veiculo != null)
            {
                // Converte as URLs para lista de FotoVeiculoDTO
                fotosEditaveis = veiculo.Fotos.Select((url, idx) => new FotoVeiculoDTO
                {
                    Id = Guid.NewGuid(), // TEMPORÁRIO - substituir pelo ID real vindo do backend
                    Url = url,
                    Ordem = idx
                }).ToList();
            }
        }
        catch { veiculo = null; }
        finally { carregando = false; }
    }

    private void ProximaFoto()
    {
        if (veiculo?.Fotos.Count > 0)
            fotoAtiva = (fotoAtiva + 1) % veiculo.Fotos.Count;
    }

    private void FotoAnterior()
    {
        if (veiculo?.Fotos.Count > 0)
            fotoAtiva = (fotoAtiva - 1 + veiculo.Fotos.Count) % veiculo.Fotos.Count;
    }

    private int? fotoFullscreenIdx;

    private void AbrirFullscreen(int idx) => fotoFullscreenIdx = idx;
    private void FecharFullscreen() => fotoFullscreenIdx = null;

    private void FsProxima()
    {
        if (fotoFullscreenIdx is null || veiculo?.Fotos.Count is null or 0) return;
        fotoFullscreenIdx = (fotoFullscreenIdx.Value + 1) % veiculo.Fotos.Count;
    }
    private void FsAnterior()
    {
        if (fotoFullscreenIdx is null || veiculo?.Fotos.Count is null or 0) return;
        fotoFullscreenIdx = (fotoFullscreenIdx.Value - 1 + veiculo.Fotos.Count) % veiculo.Fotos.Count;
    }

    private async Task AbrirModalEdicao()
    {
        // Abre o formulário direto — sem pedir senha aqui.
        // A confirmação de senha acontece no SUBMIT (botão Salvar alterações).
        formEdicao = new AtualizarVeiculoVendaDTO
        {
            Id = veiculo!.Id,
            Valor = veiculo.Valor,
            Disponibilidade = veiculo.Disponibilidade,
            TextoTermoPreliminar = veiculo.TextoTermoPreliminar
        };
        await RecarregarFotos();
        modalFormEdicaoVisivel = true;
    }

    private void AbrirModalExclusao() => modalExclusaoVisivel = true;

    private void SalvarEdicao()
    {
        // Pede a senha antes de aplicar a alteração.
        erroEdicao = null;
        modalSalvarEdicaoVisivel = true;
    }

    private async Task ConfirmarSalvarEdicao(string senha)
    {
        var ok = await VerificarSenha(senha);
        if (!ok) { modalSalvarEdicaoRef?.MostrarErro(); return; }

        modalSalvarEdicaoVisivel = false;
        salvando = true;
        try
        {
            var resultado = await VeiculoService.UpdateAsync(formEdicao);
            if (resultado.IsSuccess)
            {
                modalFormEdicaoVisivel = false;
                var atualizado = await VeiculoService.GetByIdAsync(Id);
                veiculo = atualizado.IsSuccess ? atualizado.Value : veiculo;
                StateHasChanged();
            }
            else
            {
                erroEdicao = resultado.Error ?? "Erro ao salvar.";
            }
        }
        catch
        {
            erroEdicao = "Erro de conexão.";
        }
        finally { salvando = false; }
    }

    private async Task ConfirmarExclusao(string senha)
    {
        var ok = await VerificarSenha(senha);
        if (!ok) { modalExclusaoRef?.MostrarErro(); return; }

        var resultado = await VeiculoService.RemoveAsync(veiculo!.Id);
        if (resultado.IsSuccess)
        {
            modalExclusaoVisivel = false;
            Nav.NavigateTo("/concessionaria");
        }
        else
        {
            modalExclusaoRef?.MostrarErro();
        }
    }

    private async Task<bool> VerificarSenha(string senha)
    {
        var resultado = await AuthService.VerificarSenhaAsync(UsuarioAtualId, senha);
        return resultado.IsSuccess;
    }

    private void GerarProposta() =>
        Nav.NavigateTo($"/concessionaria/proposta/nova/{Id}");

    private async Task LiberarParaVenda()
    {
        var r = await VeiculoService.LiberarParaVendaAsync(Id);
        if (r.IsSuccess) await CarregarVeiculo();
    }

    private async Task VoltarParaPreparacao()
    {
        var r = await VeiculoService.VoltarParaPreparacaoAsync(Id);
        if (r.IsSuccess) await CarregarVeiculo();
    }

    private string BadgeClass => veiculo?.Disponibilidade switch
    {
        "Disponivel"   => "badge badge-disponivel",
        "Vendido"      => "badge badge-vendido",
        "EmPreparacao" => "badge badge-preparacao",
        _              => "badge badge-reservado"
    };

    // Métodos para gerenciamento de fotos

    private async Task OnArquivoSelecionado(InputFileChangeEventArgs e)
    {
        arquivosSelecionados.Clear();
        previewsNovasFotos.Clear();
        erroUpload = null;

        foreach (var file in e.GetMultipleFiles(10))
        {
            if (file.Size > 5 * 1024 * 1024) // 5 MB
            {
                erroUpload = $"Arquivo {file.Name} excede 5MB.";
                continue;
            }
            if (!(file.ContentType == "image/jpeg" || file.ContentType == "image/png"))
            {
                erroUpload = $"Formato não suportado: {file.Name}. Use JPEG ou PNG.";
                continue;
            }

            // Lê o conteúdo do arquivo IMEDIATAMENTE — o stream do IBrowserFile
            // só é válido enquanto este handler está rodando.
            using var msArquivo = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(msArquivo);
            var bytes = msArquivo.ToArray();
            arquivosSelecionados.Add(new FotoEmMemoria(file.Name, file.ContentType, bytes));

            // Preview também a partir do mesmo conteúdo.
            var base64 = Convert.ToBase64String(bytes);
            previewsNovasFotos.Add($"data:{file.ContentType};base64,{base64}");
        }

        StateHasChanged();
    }

    private async Task UploadNovasFotos()
    {
        if (!arquivosSelecionados.Any()) return;

        uploading = true;
        erroUpload = null;
        var sucessos = 0;

        try
        {
            var arquivos = arquivosSelecionados
                .Select(f => new ArquivoUpload(
                    f.Nome,
                    f.Conteudo.Length,
                    f.ContentType,
                    () => new MemoryStream(f.Conteudo)))
                .ToList();

            var resultado = await FotoService.UploadFotosAsync("VeiculoVenda", veiculo!.Id, arquivos);
            if (resultado.IsSuccess)
            {
                sucessos = resultado.Value!.Count;
                await RecarregarFotos();
                arquivosSelecionados.Clear();
                previewsNovasFotos.Clear();
            }
            else
            {
                erroUpload = resultado.Error ?? "Erro ao enviar uma ou mais fotos.";
            }
        }
        catch (Exception ex)
        {
            erroUpload = $"Erro no upload: {ex.Message}";
        }
        finally
        {
            uploading = false;
            StateHasChanged();
        }
    }

    private void CancelarUpload()
    {
        arquivosSelecionados.Clear();
        previewsNovasFotos.Clear();
        erroUpload = null;
        StateHasChanged();
    }

    private async Task RemoverFoto(int indice)
    {
        if (indice < 0 || indice >= fotosEditaveis.Count) return;
        var foto = fotosEditaveis[indice];

        if (foto.Id != Guid.Empty)
        {
            var resultado = await VeiculoService.RemoverFotoAsync(veiculo!.Id, foto.Id);
            if (!resultado.IsSuccess)
            {
                erroUpload = resultado.Error ?? "Erro ao remover foto.";
                return;
            }
        }

        fotosEditaveis.RemoveAt(indice);
        for (int i = 0; i < fotosEditaveis.Count; i++)
            fotosEditaveis[i].Ordem = i;

        await SalvarOrdem();
        await RecarregarFotos();
    }

    private async Task MoverFotoParaCima(int indice)
    {
        if (indice <= 0) return;
        var foto = fotosEditaveis[indice];
        fotosEditaveis.RemoveAt(indice);
        fotosEditaveis.Insert(indice - 1, foto);
        for (int i = 0; i < fotosEditaveis.Count; i++)
            fotosEditaveis[i].Ordem = i;
        await SalvarOrdem();
        await RecarregarFotos();
    }

    private async Task MoverFotoParaBaixo(int indice)
    {
        if (indice >= fotosEditaveis.Count - 1) return;
        var foto = fotosEditaveis[indice];
        fotosEditaveis.RemoveAt(indice);
        fotosEditaveis.Insert(indice + 1, foto);
        for (int i = 0; i < fotosEditaveis.Count; i++)
            fotosEditaveis[i].Ordem = i;
        await SalvarOrdem();
        await RecarregarFotos();
    }

    private async Task SalvarOrdem()
    {
        var ordemIds = fotosEditaveis.Select(f => f.Id).ToList();
        var resultado = await VeiculoService.ReordenarFotosAsync(veiculo!.Id, ordemIds);
        if (!resultado.IsSuccess)
        {
            erroUpload = resultado.Error ?? "Erro ao reordenar fotos.";
        }
    }

    private async Task RecarregarFotos()
    {
        var resultado = await VeiculoService.GetByIdAsync(Id);
        if (resultado.IsSuccess && resultado.Value != null)
        {
            veiculo = resultado.Value;
            // Aqui você deve ajustar conforme seu DTO.
            // Se veiculo.Fotos já for List<FotoVeiculoDTO>, use diretamente.
            // Caso contrário, mapeie.
            fotosEditaveis = veiculo.Fotos.Select((url, idx) => new FotoVeiculoDTO
            {
                Id = Guid.NewGuid(), // ajuste para o ID real se disponível
                Url = url,
                Ordem = idx
            }).ToList();
        }
    }

    // DTO auxiliar (mova para seu domínio se necessário)
    public class FotoVeiculoDTO
    {
        public Guid Id { get; set; }
        public string Url { get; set; } = string.Empty;
        public int Ordem { get; set; }
    }
}

<style>
    /* === Galeria nova (foto sem esticar + carrossel parcial + fullscreen) === */
    .galeria-wrapper {
        max-width: 1200px; margin: 0 auto; padding: 16px;
    }
    .galeria-principal {
