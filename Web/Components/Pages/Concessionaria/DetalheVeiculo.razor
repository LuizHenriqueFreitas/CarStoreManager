        display: flex;
        gap: 8px;
        overflow-x: auto;
    }

    .thumb {
        width: 64px;
        height: 44px;
        border-radius: 4px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        flex-shrink: 0;
    }

    .thumb.ativo { border-color: #e02020; }
    .thumb img { width: 100%; height: 100%; object-fit: cover; }

    .detalhe-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px;
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 20px;
    }

    .detalhe-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
    }

    .detalhe-titulo { font-size: 24px; font-weight: 500; margin-bottom: 4px; }
    .detalhe-sub { font-size: 14px; color: #888; }

    .detalhe-section {
