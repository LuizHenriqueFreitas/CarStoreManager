        font-size: 28px;
        font-weight: 600;
        color: #e02020;
        margin-bottom: 8px;
    }

    .btn-primary {
        background: #e02020;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 12px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        width: 100%;
    }

    .btn-primary:hover { background: #c01818; }

    .btn-secondary {
        background: #fff;
        color: #1a1a1a;
        border: 0.5px solid #ccc;
        border-radius: 8px;
