        border-radius: 6px;
        font-size: 12px;
        color: #444;
        padding: 5px 10px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .acc-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #16a34a;
    }

    .preco-card {
        background: #fff;
        border-radius: 10px;
        border: 0.5px solid #e0e0e0;
        padding: 20px;
