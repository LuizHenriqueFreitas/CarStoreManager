@page "/concessionaria/proposta/nova/{VeiculoId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Vendedor")]
@rendermode InteractiveServer
@inject IPropostaVendaService PropostaVendaService
@inject IVeiculoVendaService VeiculoVendaService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Application.DTOs.Concessionaria.PropostaVenda
@using CarStoreManager.Application.DTOs.Concessionaria.VeiculoVenda
@using CarStoreManager.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization

<PageTitle>Nova Proposta</PageTitle>

<div class="form-page">
    <div class="page-header">
        <button class="btn-voltar" @onclick='() => Navigation.NavigateTo($"/concessionaria/veiculo/{VeiculoId}")'>
            ← Voltar
        </button>
        <h1 class="page-titulo">Nova proposta de venda</h1>
    </div>

    @if (carregando)
    {
        <div class="loading">Carregando dados do veículo...</div>
    }
    else if (veiculoSelecionado is null)
    {
        <div class="erro-banner">@(erro ?? "Veículo não encontrado.")</div>
    }
    else
    {
        <ClientSelector @bind-Value="form.ClienteId" />

        <VeiculoVendaInfoProposta Veiculo="veiculoSelecionado" />

        <div class="form-card">
            <h2 class="secao-titulo">Valores e condições</h2>
            <div class="form-grid">
                <div class="form-campo">
                    <label class="campo-label">Valor base (R$) *</label>
                    <input type="number" step="0.01" class="campo-input"
                           @bind="form.ValorBase" @bind:event="oninput" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Desconto (%) *</label>
                    <input type="number" step="0.5" min="0" max="100"
                           class="campo-input"
                           @bind="form.DescontoPercentual" @bind:event="oninput" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Valor com desconto (R$)</label>
                    <input type="text" class="campo-input destaque" readonly
                           value="@FormatBRL(ValorFinalCalculado)" />
                </div>
            </div>
            <p class="dica">
                Desconto vai de 0 a 100. Para 10% de desconto, digite <b>10</b>.
            </p>
        </div>

        <div class="form-card">
            <h2 class="secao-titulo">Modo de pagamento *</h2>
            <p class="dica">
                Escolha como o cliente vai pagar. Esta decisão fica vinculada à proposta;
                se for financiamento, os dados são enviados à financiadora ao registrar.
            </p>
            <div class="modo-radios">
                @foreach (var opt in ModosPagamento)
                {
                    var v = opt.valor;
                    <label class="modo-radio @(modoPagamento == v ? "ativo" : "")">
                        <input type="radio" name="modoPag"
                               checked="@(modoPagamento == v)"
                               @onchange='() => modoPagamento = v' />
                        <span class="modo-icone">@opt.icone</span>
                        <span class="modo-nome">@opt.label</span>
                    </label>
                }
            </div>

            @if (modoPagamento == "Financiamento")
            {
                <div class="financ-bloco">
                    <h3>Detalhes do financiamento</h3>
                    <div class="form-grid">
                        <div class="form-campo">
                            <label class="campo-label">Entrada (R$)</label>
                            <input type="number" step="0.01" min="0" max="@ValorFinalCalculado"
                                   class="campo-input"
                                   @bind="entrada" @bind:event="oninput" />
                        </div>
                        <div class="form-campo">
                            <label class="campo-label">Valor a financiar (R$)</label>
                            <input type="text" class="campo-input destaque" readonly
                                   value="@FormatBRL(ValorFinanciar)" />
                        </div>
                        <div class="form-campo">
                            <label class="campo-label">&nbsp;</label>
                            <label class="solicitar-check">
                                <input type="checkbox" @bind="solicitarFinanciadoraAgora" />
                                Solicitar simulação à financiadora ao criar
                            </label>
                        </div>
                    </div>
                    @if (solicitarFinanciadoraAgora)
                    {
                        <p class="dica">
                            Dados do cliente, veículo, entrada e valor a financiar serão enviados
                            por e-mail à financiadora configurada nas
                            <a href="/admin/configuracoes" target="_blank">configurações do sistema</a>.
                        </p>
                    }
                </div>
            }
            else if (modoPagamento != "NaoDefinido")
            {
                <div class="form-grid">
                    <div class="form-campo">
                        <label class="campo-label">Entrada/sinal (R$, opcional)</label>
                        <input type="number" step="0.01" min="0" max="@ValorFinalCalculado"
                               class="campo-input"
                               @bind="entrada" @bind:event="oninput" />
                    </div>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="erro-banner">@erro</div>
        }
        @if (sucesso)
        {
            <div class="sucesso-banner">Proposta registrada com sucesso!</div>
        }

        <div class="form-acoes">
            <button type="button" class="btn-cancelar"
                    @onclick='() => Navigation.NavigateTo($"/concessionaria/veiculo/{VeiculoId}")'>
                Cancelar
            </button>
            <button type="button" class="btn-salvar"
                    @onclick="Salvar"
                    disabled="@salvando">
                @(salvando ? "Salvando..." : "Registrar proposta")
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid VeiculoId { get; set; }

    private CriarPropostaVendaDTO form = new();
    private VeiculoVendaDTO? veiculoSelecionado;
    private bool carregando = true;
    private bool salvando = false;
    private bool sucesso = false;
    private string? erro;

    private string modoPagamento = "NaoDefinido";
    private decimal entrada;
    private bool solicitarFinanciadoraAgora = true;
    private decimal ValorFinanciar => Math.Max(0m, ValorFinalCalculado - entrada);

    private static readonly (string valor, string label, string icone)[] ModosPagamento =
    {
        ("Dinheiro", "Dinheiro", "💵"),
        ("Pix", "Pix", "⚡"),
        ("CartaoDebito", "Débito", "💳"),
        ("CartaoCredito", "Crédito", "💳"),
        ("Financiamento", "Financiamento", "🏦"),
        ("Boleto", "Boleto", "📄"),
        ("Transferencia", "Transferência", "🔁"),
    };

    private decimal ValorFinalCalculado
    {
        get
        {
            if (form.DescontoPercentual < 0) return form.ValorBase;
            if (form.DescontoPercentual > 100) return 0;
            return Math.Round(form.ValorBase * (1 - form.DescontoPercentual / 100m), 2);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Vendedor logado vira o autor da proposta.
            var state = await AuthState.GetAuthenticationStateAsync();
            var idClaim = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (idClaim is not null && Guid.TryParse(idClaim.Value, out var vendedorId))
                form.VendedorId = vendedorId;

            var veiculoResult = await VeiculoVendaService.GetByIdAsync(VeiculoId);
            if (veiculoResult.IsSuccess && veiculoResult.Value is not null)
            {
                veiculoSelecionado = veiculoResult.Value;
                form.VeiculoVendaId = VeiculoId;
                form.ValorBase = veiculoSelecionado.Valor;
                form.DescontoPercentual = 0;
            }
            else
            {
                erro = veiculoResult.Error ?? "Veículo não encontrado.";
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar veículo: {ex.Message}";
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task Salvar()
    {
        if (form.ClienteId == Guid.Empty)
        {
            erro = "Selecione ou cadastre um cliente.";
            return;
        }
        if (form.VeiculoVendaId == Guid.Empty)
        {
            erro = "Veículo inválido.";
            return;
        }
        if (form.ValorBase <= 0)
        {
            erro = "Valor base deve ser maior que zero.";
            return;
        }
        if (form.DescontoPercentual < 0 || form.DescontoPercentual > 100)
        {
            erro = "Desconto deve estar entre 0 e 100.";
            return;
        }
        if (modoPagamento == "NaoDefinido")
        {
            erro = "Selecione o modo de pagamento.";
            return;
        }
        if (entrada < 0 || entrada > ValorFinalCalculado)
        {
            erro = "Entrada deve estar entre 0 e o valor final.";
            return;
        }

        salvando = true;
        erro = null;
        sucesso = false;

        try
        {
            // Cria a proposta (vem como Criada, modo NaoDefinido).
            var resultado = await PropostaVendaService.AddAsync(form);
            if (!resultado.IsSuccess) { erro = resultado.Error; return; }

            var propostaId = resultado.Value;

            // Define modo de pagamento escolhido na criação.
            var rModo = await PropostaVendaService.DefinirModoPagamentoAsync(propostaId, modoPagamento);
            if (!rModo.IsSuccess)
            {
                erro = $"Proposta criada, mas falha ao definir modo: {rModo.Error}";
                return;
            }

            // Define entrada (mesmo se 0, mantém consistência).
            if (entrada > 0)
            {
                var rEnt = await PropostaVendaService.DefinirEntradaAsync(new DefinirEntradaDTO
                {
                    PropostaId = propostaId, ValorEntrada = entrada
                });
                if (!rEnt.IsSuccess)
                {
                    erro = $"Proposta criada, mas falha ao definir entrada: {rEnt.Error}";
                    return;
                }
            }

            // Se financiamento + opt-in, dispara solicitação à financiadora.
            if (modoPagamento == "Financiamento" && solicitarFinanciadoraAgora)
            {
                var rFin = await PropostaVendaService.SolicitarFinanciamentoAsync(propostaId);
                if (!rFin.IsSuccess)
                {
                    // Não bloqueia a navegação — proposta foi criada com sucesso.
                    // Admin pode reenviar do detalhe.
                    erro = $"Proposta criada com financiamento mas houve falha no envio à financiadora: {rFin.Error}. Você pode reenviar do detalhe.";
                    sucesso = true;
                    await Task.Delay(2500);
                    Navigation.NavigateTo($"/concessionaria/proposta/{propostaId}");
                    return;
                }
            }

            sucesso = true;
            await Task.Delay(700);
            Navigation.NavigateTo($"/concessionaria/proposta/{propostaId}");
        }
        catch (Exception ex)
        {
            erro = $"Erro ao criar proposta: {ex.Message}";
        }
        finally
        {
            salvando = false;
        }
    }

    private static string FormatBRL(decimal v)
        => v.ToString("C", new CultureInfo("pt-BR"));
}

<style>
    .form-page { max-width: 800px; margin: 0 auto; padding: 24px; }
    .page-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
    .btn-voltar { background: none; border: none; color: #888; font-size: 14px; cursor: pointer; padding: 0; }
    .btn-voltar:hover { color: #1a1a1a; }
    .page-titulo { font-size: 22px; font-weight: 500; }

    .form-card {
        background: #fff;
        border: 0.5px solid #e0e0e0;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
    }
    .secao-titulo {
        font-size: 14px;
        font-weight: 500;
        color: #1a1a1a;
        margin-bottom: 16px;
        padding-bottom: 10px;
        border-bottom: 0.5px solid #eee;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
    }
    .form-campo { display: flex; flex-direction: column; gap: 6px; }
    .campo-label { font-size: 12px; color: #555; font-weight: 500; }
    .campo-input {
        border: 0.5px solid #ccc;
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 14px;
        outline: none;
        width: 100%;
    }
    .campo-input:focus { border-color: #e02020; }
    .campo-input.destaque {
        background: #fff5f5;
        border-color: #fca5a5;
        font-weight: 600;
        color: #c01818;
    }
    .dica { font-size: 12px; color: #888; margin-top: 8px; }

    .erro-banner {
        background: #fff5f5;
        border: 0.5px solid #fca5a5;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 13px;
        color: #e02020;
        margin-bottom: 16px;
    }
    .sucesso-banner {
        background: #f0fdf4;
        border: 0.5px solid #86efac;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 13px;
        color: #166534;
        margin-bottom: 16px;
    }
    .loading { text-align: center; padding: 40px; color: #888; font-size: 14px; }

    .form-acoes {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 8px;
    }
    .btn-cancelar {
        background: #fff;
        border: 0.5px solid #ccc;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 14px;
        cursor: pointer;
        color: #444;
    }
    .btn-salvar {
        background: #e02020;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 24px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }
    .btn-salvar:hover:not(:disabled) { background: #c01818; }
    .btn-salvar:disabled { opacity: 0.6; cursor: not-allowed; }

    /* === Modo de pagamento === */
    .modo-radios {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 8px;
        margin: 12px 0;
    }
    .modo-radio {
        display: flex; flex-direction: column; align-items: center;
        gap: 6px; padding: 12px 6px;
        border: 1px solid #ccc; border-radius: 8px;
        cursor: pointer; transition: all 0.15s;
        background: #fff;
    }
    .modo-radio:hover { border-color: #0a84ff; background: #f5faff; }
    .modo-radio.ativo {
        border-color: #0a84ff; background: #e0f2fe;
        box-shadow: 0 0 0 2px rgba(10,132,255,0.2);
    }
    .modo-radio input[type="radio"] { display: none; }
    .modo-icone { font-size: 1.4rem; }
    .modo-nome { font-size: 0.88em; font-weight: 500; color: #333; }

    .financ-bloco {
        background: #f8fafc; border: 1px solid #cbd5e1;
        border-radius: 8px; padding: 14px 16px; margin-top: 14px;
    }
    .financ-bloco h3 {
        font-size: 0.95rem; margin: 0 0 12px;
        color: #1f4d8c;
    }
    .solicitar-check {
        display: flex; gap: 8px; align-items: center;
        font-size: 0.9em; padding: 8px 0; cursor: pointer;
    }
</style>
