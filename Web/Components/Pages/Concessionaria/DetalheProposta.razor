@page "/concessionaria/proposta/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Vendedor")]
@rendermode InteractiveServer
@inject IPropostaVendaService PropostaService
@inject IClienteService ClienteService
@inject IVeiculoVendaService VeiculoService
@inject NavigationManager Nav

@using System.Globalization
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Application.DTOs.Concessionaria.PropostaVenda
@using CarStoreManager.Application.DTOs.Concessionaria.VeiculoVenda
@using CarStoreManager.Application.DTOs.Shared.Cliente
@using CarStoreManager.Web.Components.Shared

<div class="prop-page">
    <div class="page-header">
        <button class="btn-link" @onclick='() => Nav.NavigateTo("/concessionaria/propostas")'>← Voltar</button>
        <h1 class="page-titulo">Proposta @(proposta is null ? "" : "#" + proposta.Id.ToString()[..8].ToUpper())</h1>
    </div>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="banner @(mensagemErro ? "banner-erro" : "banner-ok")">@mensagem</div>
    }

    @if (carregando)
    {
        <p class="muted">Carregando...</p>
    }
    else if (proposta is null)
    {
        <p class="muted">Proposta não encontrada.</p>
    }
    else
    {
        <div class="status-bar">
            <span class="status-tag tag-@proposta.Status.ToLower()">@StatusLabel(proposta.Status)</span>
            @if (proposta.Status is "Criada" or "AguardandoFinanciadora" or "PropostaFinanciadoraRecebida")
            {
                <span class="dias">
                    @if (proposta.DiasRestantes > 0)
                    {
                        <span>Expira em @proposta.DiasRestantes dia(s)</span>
                    }
                    else
                    {
                        <span class="dias-vencido">Já passou do prazo</span>
                    }
                </span>
            }
            @if (!string.IsNullOrEmpty(proposta.MotivoRejeicao))
            { <span class="muted">— Rejeitada: @proposta.MotivoRejeicao</span> }
            @if (!string.IsNullOrEmpty(proposta.MotivoCancelamento))
            { <span class="muted">— Cancelada: @proposta.MotivoCancelamento</span> }
        </div>

        <div class="grid-2">
            <section class="card">
                <h2>Cliente</h2>
                @if (cliente is not null)
                {
                    <p><b>@cliente.Nome</b><br/>
                       CPF @cliente.Cpf<br/>
                       Tel @cliente.Telefone<br/>
                       @cliente.Email</p>
                }
                else { <p class="muted">…</p> }
            </section>

            <section class="card">
                <h2>Veículo</h2>
                @if (veiculo is not null)
                {
                    <p><b>@veiculo.Marca @veiculo.Modelo</b><br/>
                       Ano @veiculo.Ano · Placa @veiculo.Placa<br/>
                       @veiculo.Cor · @veiculo.Quilometragem.ToString("N0") km</p>
                }
                else { <p class="muted">…</p> }
            </section>
        </div>

        <section class="card">
            <h2>Valores</h2>
            <table class="tbl-valores">
                <tr><td>Valor base</td><td>@FormatBRL(proposta.ValorBase)</td></tr>
                <tr><td>Desconto</td><td>@proposta.DescontoPercentual.ToString("N2")%</td></tr>
                <tr><td><b>Valor final</b></td><td><b>@FormatBRL(proposta.ValorFinal)</b></td></tr>
                <tr><td>Entrada</td><td>@FormatBRL(proposta.Entrada)</td></tr>
                <tr><td>A financiar</td><td>@FormatBRL(proposta.ValorLiquidoFinanciamento)</td></tr>
            </table>

            @if (PodeEditar)
            {
                <div class="entrada-edit">
                    <label>Atualizar entrada (R$):</label>
                    <input type="number" step="0.01" min="0" @bind="novaEntrada" />
                    <button class="btn-sec" @onclick="AtualizarEntrada">Salvar</button>
                </div>
            }
        </section>

        <section class="card">
            <h2>Modo de pagamento</h2>
            <p><b>@ModoPagamentoLabel(proposta.ModoPagamento)</b></p>
            <p class="muted small">
                O modo de pagamento é definido na criação da proposta e não pode ser alterado depois.
                Se for necessário trocar, cancele esta proposta e crie uma nova.
            </p>
        </section>

        @if (proposta.ModoPagamento == "Financiamento" || proposta.ParcelasFinanciamento.HasValue)
        {
            <section class="card">
                <h2>Financiamento</h2>

                @if (proposta.Status == "Criada" && proposta.ModoPagamento == "Financiamento")
                {
                    <p class="muted">
                        Pronto para enviar dados à financiadora configurada nas
                        <a href="/admin/configuracoes">configurações do sistema</a>.
                    </p>
                    <button class="btn-primary" @onclick="SolicitarFinanciamento" disabled="@processando">
                        @(processando ? "Enviando..." : "📧 Solicitar simulação à financiadora")
                    </button>
                }
                else if (proposta.Status == "AguardandoFinanciadora")
                {
                    <p>
                        ⏳ Aguardando retorno da financiadora desde
                        <b>@proposta.DataSolicitacaoFinanciamento?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</b>.
                    </p>
                    <h3>Registrar resposta da financiadora</h3>
                    <div class="form-row">
                        <label>Parcelas</label>
                        <input type="number" min="1" @bind="financ.Parcelas" />
                        <label>Valor parcela (R$)</label>
                        <input type="number" step="0.01" min="0" @bind="financ.ValorParcela" />
                        <label>Taxa juros mensal (%)</label>
                        <input type="number" step="0.01" min="0" @bind="financ.TaxaJurosMensal" />
                    </div>
                    <textarea placeholder="Observações da financiadora (opcional)"
                              @bind="financ.Observacoes" rows="3"></textarea>
                    <button class="btn-primary" @onclick="RegistrarResposta" disabled="@processando">
                        Registrar resposta
                    </button>
                }
                else if (proposta.ParcelasFinanciamento.HasValue)
                {
                    <table class="tbl-valores">
                        <tr><td>Parcelas</td><td>@proposta.ParcelasFinanciamento×</td></tr>
                        <tr><td>Valor parcela</td><td>@FormatBRL(proposta.ValorParcela ?? 0)</td></tr>
                        <tr><td>Taxa juros mensal</td><td>@proposta.TaxaJurosMensal?.ToString("N2")%</td></tr>
                        <tr><td>Total financiado</td><td>@FormatBRL((proposta.ValorParcela ?? 0) * (proposta.ParcelasFinanciamento ?? 0))</td></tr>
                        @if (!string.IsNullOrEmpty(proposta.ObservacoesFinanciamento))
                        {
                            <tr><td>Observações</td><td>@proposta.ObservacoesFinanciamento</td></tr>
                        }
                    </table>
                    <p class="muted">
                        Resposta registrada em @proposta.DataRespostaFinanciadora?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </p>
                }
            </section>
        }

        @if (proposta.Status is "Aprovada" or "AguardandoVistoria" or "VistoriaConcluida"
            or "AguardandoAssinaturaTermo" or "Concluida")
        {
            <section class="card">
                <h2>Vistoria do veículo</h2>

                @if (proposta.Status == "Aprovada")
                {
                    <p class="muted">Próximo passo: iniciar vistoria do veículo antes da entrega.</p>
                    <button class="btn-primary" @onclick="IniciarVistoria" disabled="@processando">
                        🔍 Iniciar vistoria
                    </button>
                }
                else if (proposta.Status == "AguardandoVistoria")
                {
                    var vistoriaAtual = vistorias.FirstOrDefault(v => !v.Concluida);
                    @if (vistoriaAtual is not null)
                    {
                        <UploadFotosEntidade
                            EntidadeTipo="Vistoria"
                            EntidadeId="vistoriaAtual.Id"
                            Titulo="Fotos da vistoria"
                            Descricao="Anexe fotos do veículo (avarias, painéis, motor, hodômetro etc.) antes de registrar o resultado." />
                    }

                    <h3>Registrar resultado</h3>
                    <textarea placeholder="Descreva o estado do veículo, equipamentos, avarias visíveis, quilometragem, etc."
                              @bind="vistoriaObs" rows="5"></textarea>
                    <div class="vistoria-decisao">
                        <button class="btn-aprovar small" @onclick="() => RegistrarVistoria(true)" disabled="@processando">
                            ✓ Aprovar (veículo OK)
                        </button>
                        <button class="btn-rejeitar small" @onclick="() => RegistrarVistoria(false)" disabled="@processando">
                            ✗ Reprovar (precisa nova vistoria)
                        </button>
                    </div>
                }

                @if (vistorias.Any(v => v.Concluida))
                {
                    <h3>Histórico</h3>
                    <ul class="vistoria-lista">
                        @foreach (var v in vistorias.Where(x => x.Concluida))
                        {
                            <li>
                                <div>
                                    <span class="@(v.Aprovado ? "v-ok" : "v-fail")">
                                        @(v.Aprovado ? "✓ Aprovada" : "✗ Reprovada")
                                    </span>
                                    em @v.DataRealizada.ToLocalTime().ToString("dd/MM/yyyy HH:mm") —
                                    @v.Observacoes
                                </div>
                                <UploadFotosEntidade
                                    EntidadeTipo="Vistoria"
                                    EntidadeId="v.Id"
                                    Titulo=""
                                    PodeEditar="false" />
                            </li>
                        }
                    </ul>
                }
            </section>
        }

        @if (proposta.Status is "Aprovada" or "AguardandoVistoria" or "VistoriaConcluida"
            or "AguardandoAssinaturaTermo" or "Concluida")
        {
            <PainelPagamentoProposta PropostaId="proposta.Id" />
        }

        @if (proposta.Status is "VistoriaConcluida" or "AguardandoAssinaturaTermo" or "Concluida")
        {
            <section class="card">
                <h2>Termo de entrega</h2>

                @if (termo is null && proposta.Status == "VistoriaConcluida")
                {
                    <p class="muted">Redija o termo descrevendo as condições do veículo na entrega.
                        Esse texto terá valor jurídico — seja específico (avarias, equipamentos, km).</p>
                    <textarea @bind="termoTexto" rows="10"
                              placeholder="Ex: O veículo é entregue na data acima, em pleno funcionamento, com [equipamentos], quilometragem [X], sem avarias visíveis exceto [...]. O cliente declara ciência..."></textarea>
                    <button class="btn-primary" @onclick="SalvarTermo" disabled="@processando">
                        💾 Criar termo (rascunho)
                    </button>
                }
                else if (termo is not null)
                {
                    <p>Status: <b>@StatusTermoLabel(termo.Status)</b>
                        @if (termo.DataUltimaEdicao.HasValue)
                        {
                            <span class="muted">— editado em @termo.DataUltimaEdicao.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        }
                    </p>

                    @if (termo.Status == "Rascunho")
                    {
                        <textarea @bind="termoTexto" rows="10"></textarea>
                        <button class="btn-sec" @onclick="SalvarTermo" disabled="@processando">Salvar alterações</button>
                        <button class="btn-primary" @onclick="EnviarTermo" disabled="@processando">
                            📨 Enviar para assinatura do cliente
                        </button>
                    }
                    else if (termo.Status == "AguardandoAssinatura")
                    {
                        <p class="muted">Compartilhe este link com o cliente para que ele assine:</p>
                        <input type="text" readonly value="@LinkAssinatura" class="link-share" @onclick="SelecionarLink" />
                        <h3>Conteúdo</h3>
                        <pre class="termo-preview">@termo.TextoTermo</pre>
                    }
                    else if (termo.Status == "Assinado")
                    {
                        <div class="banner banner-ok">
                            ✓ Assinado em @termo.DataAssinatura?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            por <b>@termo.AssinaturaNomeCliente</b> (CPF @termo.AssinaturaCpfCliente)
                            do IP @termo.AssinaturaIp.
                        </div>
                        <h3>Conteúdo do termo</h3>
                        <pre class="termo-preview">@termo.TextoTermo</pre>
                    }
                }
            </section>
        }

        @if (PodeEditar)
        {
            <section class="card acoes">
                <h2>Ações</h2>
                <button class="btn-aprovar" @onclick="Aprovar" disabled="@processando">
                    ✓ Cliente aprova proposta
                </button>

                <div class="motivo-bloco">
                    <input type="text" placeholder="Motivo (obrigatório)" @bind="motivo" />
                    <button class="btn-rejeitar" @onclick="Rejeitar"
                            disabled="@(string.IsNullOrWhiteSpace(motivo) || processando)">
                        Rejeitar
                    </button>
                    <button class="btn-cancelar" @onclick="Cancelar"
                            disabled="@(string.IsNullOrWhiteSpace(motivo) || processando)">
                        Cancelar
                    </button>
                </div>
            </section>
        }
    }
</div>

<style>
    .prop-page { max-width: 980px; margin: 0 auto; padding: 24px; }
    .page-header { display:flex; align-items:center; gap:16px; margin-bottom:20px; }
    .btn-link { background:none; border:0; color:#888; cursor:pointer; }
    .page-titulo { margin:0; font-size:1.4rem; }
    .banner { padding:12px 16px; border-radius:6px; margin-bottom:16px; }
    .banner-ok { background:#e6f7ed; color:#1f7a3a; border:1px solid #b6e4c2; }
    .banner-erro { background:#fdecea; color:#a72020; border:1px solid #f5c2bd; }
    .muted { color:#888; font-size:0.9em; }
    .small { font-size:0.85em; }
    .status-bar { display:flex; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap; }
    .status-tag { padding:4px 12px; border-radius:14px; font-size:0.9em; font-weight:500; }
    .tag-criada { background:#e0f2fe; color:#075985; }
    .tag-aguardandofinanciadora { background:#fff5d9; color:#8a6d00; }
    .tag-propostafinanciadorarecebida { background:#ede9fe; color:#5b21b6; }
    .tag-aprovada { background:#dcfce7; color:#166534; }
    .tag-rejeitada { background:#fff5f5; color:#e02020; }
    .tag-cancelada { background:#fef9c3; color:#854d0e; }
    .tag-expirada { background:#f3f4f6; color:#6b7280; }
    .dias { color:#666; font-size:0.9em; }
    .dias-vencido { color:#a72020; font-weight:500; }
    .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px; }
    .card { background:#fff; border:1px solid #e5e5e5; border-radius:8px; padding:18px; margin-bottom:16px; }
    .card h2 { margin:0 0 12px; font-size:1.05rem; }
    .card h3 { font-size:0.95rem; margin:14px 0 8px; }
    .card p { margin:6px 0; }
    .tbl-valores { width:100%; }
    .tbl-valores td { padding:6px 4px; border-bottom:1px solid #f0f0f0; }
    .tbl-valores td:last-child { text-align:right; }
    .entrada-edit { display:flex; gap:8px; align-items:center; margin-top:12px; padding-top:12px; border-top:1px dashed #eee; }
    .entrada-edit input { padding:6px 10px; border:1px solid #ccc; border-radius:4px; width:140px; }
    select { padding:8px; border:1px solid #ccc; border-radius:4px; min-width:200px; margin-right:8px; }
    .form-row { display:grid; grid-template-columns:auto 1fr auto 1fr auto 1fr; gap:8px; align-items:center; margin-bottom:10px; }
    .form-row label { font-weight:500; font-size:0.9em; }
    .form-row input { padding:6px 10px; border:1px solid #ccc; border-radius:4px; }
    textarea { width:100%; padding:8px; border:1px solid #ccc; border-radius:4px; resize:vertical; margin-bottom:10px; }
    .btn-primary { background:#0a84ff; color:#fff; padding:10px 20px; border-radius:6px; border:0; cursor:pointer; font-weight:500; }
    .btn-primary:disabled { background:#aaa; cursor:not-allowed; }
    .btn-sec { background:#666; color:#fff; padding:6px 14px; border-radius:4px; border:0; cursor:pointer; }
    .btn-aprovar { background:#1f7a3a; color:#fff; padding:12px 24px; border-radius:6px; border:0; cursor:pointer; font-weight:500; margin-bottom:16px; display:block; }
    .btn-aprovar:disabled { background:#aaa; cursor:not-allowed; }
    .motivo-bloco { display:flex; gap:8px; }
    .motivo-bloco input { flex:1; padding:8px; border:1px solid #ccc; border-radius:4px; }
    .btn-rejeitar { background:#a72020; color:#fff; padding:8px 16px; border-radius:6px; border:0; cursor:pointer; }
    .btn-cancelar { background:#854d0e; color:#fff; padding:8px 16px; border-radius:6px; border:0; cursor:pointer; }
    .btn-rejeitar:disabled, .btn-cancelar:disabled { background:#ccc; cursor:not-allowed; }
    .vistoria-decisao { display:flex; gap:8px; margin-top:10px; }
    .btn-aprovar.small, .btn-rejeitar.small { padding:8px 14px; font-size:0.9em; margin-bottom:0; display:inline-block; }
    .vistoria-lista { padding-left:18px; }
    .vistoria-lista li { margin:6px 0; }
    .v-ok { color:#1f7a3a; font-weight:500; }
    .v-fail { color:#a72020; font-weight:500; }
    .link-share { width:100%; padding:8px; border:1px solid #0a84ff; border-radius:4px; background:#f0f8ff; font-family:monospace; font-size:0.85em; }
    .termo-preview { background:#f8f8f8; border:1px solid #e0e0e0; border-radius:6px; padding:14px; white-space:pre-wrap; font-family:Georgia,serif; font-size:0.92em; line-height:1.5; max-height:300px; overflow:auto; }
    .tag-aguardandovistoria { background:#fff5d9; color:#8a6d00; }
    .tag-vistoriaconcluida { background:#cffafe; color:#0e7490; }
    .tag-aguardandoassinaturatermo { background:#fef3c7; color:#854d0e; }
    .tag-concluida { background:#d1fae5; color:#065f46; }
</style>

@code {
    [Parameter] public Guid Id { get; set; }

    private PropostaVendaDTO? proposta;
    private ClienteDTO? cliente;
    private VeiculoVendaDTO? veiculo;
    private bool carregando = true;
    private bool processando;
    private string mensagem = "";
    private bool mensagemErro;
    private decimal novaEntrada;
    private string motivo = "";
    private RegistrarRespostaFinanciadoraDTO financ = new();

    private List<VistoriaDTO> vistorias = new();
    private TermoEntregaDTO? termo;
    private string vistoriaObs = "";
    private string termoTexto = "";
    private string LinkAssinatura =>
        termo?.TokenAssinatura is null ? "" :
        $"{Nav.BaseUri.TrimEnd('/')}/concessionaria/assinar/{termo.TokenAssinatura}";

    private bool PodeEditar => proposta is not null
        && proposta.Status is "Criada" or "AguardandoFinanciadora" or "PropostaFinanciadoraRecebida";

    protected override async Task OnInitializedAsync() => await Carregar();

    private async Task Carregar()
    {
        carregando = true;
        var r = await PropostaService.GetByIdAsync(Id);
        if (r.IsSuccess)
        {
            proposta = r.Value;
            novaEntrada = proposta!.Entrada;

            var rc = await ClienteService.GetByIdAsync(proposta.ClienteId);
            if (rc.IsSuccess) cliente = rc.Value;

            var rv = await VeiculoService.GetByIdAsync(proposta.VeiculoVendaId);
            if (rv.IsSuccess) veiculo = rv.Value;

            // Vistorias + termo (carregamento opcional, falha silenciosa)
            var rVist = await PropostaService.ListarVistoriasAsync(Id);
            if (rVist.IsSuccess) vistorias = rVist.Value!.ToList();

            var rTermo = await PropostaService.ObterTermoAsync(Id);
            if (rTermo.IsSuccess)
            {
                termo = rTermo.Value;
                termoTexto = termo!.TextoTermo;
            }
        }
        else MostrarErro(r.Error);
        carregando = false;
    }

    private async Task IniciarVistoria()
    {
        processando = true;
        var r = await PropostaService.IniciarVistoriaAsync(Id, Guid.Empty);
        processando = false;
        if (r.IsSuccess) { MostrarOk("Vistoria iniciada — anexe fotos do veículo e registre o resultado."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task RegistrarVistoria(bool aprovado)
    {
        if (string.IsNullOrWhiteSpace(vistoriaObs))
        { MostrarErro("Preencha as observações da vistoria."); return; }

        processando = true;
        var r = await PropostaService.RegistrarVistoriaAsync(Id, Guid.Empty, new RegistrarVistoriaDTO
        {
            Observacoes = vistoriaObs, Aprovado = aprovado
        });
        processando = false;
        if (r.IsSuccess) { MostrarOk(aprovado ? "Vistoria aprovada." : "Vistoria reprovada — registre nova quando o veículo estiver OK."); vistoriaObs = ""; await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task SalvarTermo()
    {
        if (string.IsNullOrWhiteSpace(termoTexto))
        { MostrarErro("O texto do termo é obrigatório."); return; }

        processando = true;
        var r = await PropostaService.CriarOuEditarTermoAsync(Id, Guid.Empty,
            new CriarOuEditarTermoDTO { TextoTermo = termoTexto });
        processando = false;
        if (r.IsSuccess) { MostrarOk("Termo salvo."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task EnviarTermo()
    {
        processando = true;
        var r = await PropostaService.EnviarTermoParaAssinaturaAsync(Id);
        processando = false;
        if (r.IsSuccess) { MostrarOk("Termo liberado para assinatura. Compartilhe o link com o cliente."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private void SelecionarLink() { /* placeholder para futuro copy-to-clipboard */ }

    private static string StatusTermoLabel(string s) => s switch
    {
        "Rascunho" => "Rascunho (admin pode editar)",
        "AguardandoAssinatura" => "Aguardando assinatura do cliente",
        "Assinado" => "Assinado",
        _ => s
    };

    private async Task AtualizarEntrada()
    {
        processando = true;
        var r = await PropostaService.DefinirEntradaAsync(new DefinirEntradaDTO
        {
            PropostaId = Id, ValorEntrada = novaEntrada
        });
        processando = false;
        if (r.IsSuccess) { MostrarOk("Entrada atualizada."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task SolicitarFinanciamento()
    {
        processando = true;
        var r = await PropostaService.SolicitarFinanciamentoAsync(Id);
        processando = false;
        if (r.IsSuccess) { MostrarOk("Solicitação enviada à financiadora."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task RegistrarResposta()
    {
        if (financ.Parcelas <= 0 || financ.ValorParcela <= 0)
        { MostrarErro("Preencha parcelas e valor da parcela."); return; }

        processando = true;
        var r = await PropostaService.RegistrarRespostaFinanciadoraAsync(Id, financ);
        processando = false;
        if (r.IsSuccess) { MostrarOk("Resposta registrada."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task Aprovar()
    {
        processando = true;
        var r = await PropostaService.AprovarAsync(Id);
        processando = false;
        if (r.IsSuccess) { MostrarOk("Proposta aprovada."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task Rejeitar()
    {
        if (string.IsNullOrWhiteSpace(motivo)) return;
        processando = true;
        var r = await PropostaService.RejeitarAsync(Id, motivo);
        processando = false;
        if (r.IsSuccess) { MostrarOk("Proposta rejeitada."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private async Task Cancelar()
    {
        if (string.IsNullOrWhiteSpace(motivo)) return;
        processando = true;
        var r = await PropostaService.CancelarAsync(Id, motivo);
        processando = false;
        if (r.IsSuccess) { MostrarOk("Proposta cancelada."); await Carregar(); }
        else MostrarErro(r.Error);
    }

    private void MostrarOk(string? msg) { mensagem = msg ?? ""; mensagemErro = false; }
    private void MostrarErro(string? msg) { mensagem = msg ?? "Erro"; mensagemErro = true; }

    private static string FormatBRL(decimal v)
        => v.ToString("C", new CultureInfo("pt-BR"));

    private static string StatusLabel(string s) => s switch
    {
        "Criada" => "Ativa",
        "AguardandoFinanciadora" => "Aguardando financiadora",
        "PropostaFinanciadoraRecebida" => "Resposta da financiadora recebida",
        "Aprovada" => "Aprovada pelo cliente",
        "Rejeitada" => "Rejeitada",
        "Cancelada" => "Cancelada",
        "Expirada" => "Expirada (>7 dias)",
        _ => s
    };

    private static string ModoPagamentoLabel(string s) => s switch
    {
        "NaoDefinido" => "— Não definido —",
        "Dinheiro" => "Dinheiro",
        "Pix" => "Pix",
        "CartaoDebito" => "Cartão de débito",
        "CartaoCredito" => "Cartão de crédito",
        "Financiamento" => "Financiamento",
        "Boleto" => "Boleto",
        "Transferencia" => "Transferência",
        _ => s
    };
}
