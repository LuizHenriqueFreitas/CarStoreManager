@page "/concessionaria"

@using CarStoreManager.Web.Imports
@inject IVeiculoService VeiculoService

<div class="layout">

    <!-- TOPO -->
    <div class="topo">
        <SeletorWorkspace />

        <div class="usuario">
            Usuário logado
        </div>
    </div>

    <!-- CONTEÚDO -->
    <div class="conteudo">

        <!-- ESQUERDA -->
        <div class="painel-esquerdo">

            <input placeholder="Buscar por nome..." @bind="busca" />

            <table class="tabela">
                <thead>
                    <tr>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th>Ano</th>
                        <th>Cor</th>
                        <th>KM</th>
                        <th>Valor</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var v in Filtrados())
                    {
                        <tr @onclick="() => Selecionar(v)">
                            <td>@v.Marca</td>
                            <td>@v.Modelo</td>
                            <td>@v.Ano</td>
                            <td>@v.Cor</td>
                            <td>@v.Quilometragem</td>
                            <td>@v.Valor</td>
                            <td>@(v.Disponivel ? "Disponível" : "Vendido")</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

        <!-- DIREITA -->
        <div class="painel-direito">

            @if (veiculoSelecionado != null)
            {
                <VeiculoImagem Veiculo="veiculoSelecionado" />
                <VeiculoDetalhes Veiculo="veiculoSelecionado" />
                <VeiculoFinanceiro Veiculo="veiculoSelecionado" />
            }
            else
            {
                <p>Selecione um veículo...</p>
            }

        </div>

    </div>

    <!-- RODAPÉ -->
    <div class="rodape">
        <button @onclick="AbrirModal">Cadastrar novo carro</button>
        <button>Atualizar dados</button>
        <button>Gerar proposta</button>
    </div>

</div>

<ModalNovoVeiculo OnSalvar="SalvarVeiculo" @ref="modal" />

@code {
    private ModalNovoVeiculo? modal;

    private List<VeiculoDTO> veiculos = new();
    private VeiculoDTO? veiculoSelecionado;

    private string busca = "";

    protected override async Task OnInitializedAsync()
    {
        await CarregarVeiculos();
    }

    async Task CarregarVeiculos()
    {
        var result = await VeiculoService.ObterTodosAsync();

        if (result.Success)
            veiculos = result.Data?.ToList() ?? new();
    }

    IEnumerable<VeiculoDTO> Filtrados()
    {
        if (string.IsNullOrWhiteSpace(busca))
            return veiculos;

        return veiculos.Where(v =>
            v.Marca.Contains(busca, StringComparison.OrdinalIgnoreCase) ||
            v.Modelo.Contains(busca, StringComparison.OrdinalIgnoreCase));
    }

    void Selecionar(VeiculoDTO v)
    {
        veiculoSelecionado = v;
    }

    void AbrirModal()
    {
        modal?.Abrir();
    }

    async Task SalvarVeiculo(VeiculoDTO novo)
    {
        var result = await VeiculoService.CriarAsync(novo);

        if (result.Success)
            await CarregarVeiculos();
    }
}