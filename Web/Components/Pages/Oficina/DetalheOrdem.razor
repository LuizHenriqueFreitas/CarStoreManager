@page "/oficina/os/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Mecanico,Recepcionista")]

@namespace CarStoreManager.Web.Components.Pages

@inject IOrdemServicoService OrdemService
@inject IComponenteService ComponenteService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Application.DTOs.Oficina.OrdemServico
@using CarStoreManager.Application.DTOs.Oficina.Componente
@using CarStoreManager.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web

@if (carregando)
{
    <div class="loading">Carregando...</div>
}
else if (os is null)
{
    <div class="loading">Ordem de serviço não encontrada.</div>
}
else
{
    <div class="detalhe-page">
        <div class="detalhe-header">
            <button class="btn-voltar" @onclick='() => Nav.NavigateTo("/oficina")'>
                ← Voltar
            </button>
            <div class="header-info">
                <div class="os-numero-grande">OS @os.NumeroPublico</div>
                <span class="os-status @StatusClass(os.Status)">@StatusLabel(os.Status)</span>
            </div>
            <div class="header-acoes">
                @if (PodeEnviarRevisao)
                {
                    <button class="btn-acao azul" @onclick="EnviarRevisao">Enviar para revisão</button>
                }
                @if (PodeAprovarMecanico)
                {
                    <button class="btn-acao azul" @onclick="AprovarMecanico">Aprovar orçamento</button>
                    <button class="btn-acao laranja" @onclick="Devolver">Pedir ajustes</button>
                }
                @if (PodeMarcarClienteAprovou)
                {
                    <button class="btn-acao verde" @onclick="ClienteAprovou">Cliente aprovou</button>
                }
                @if (PodeIniciar)
                {
                    <button class="btn-acao azul" @onclick="IniciarOS">Iniciar serviço</button>
                }
                @if (PodeFinalizar)
                {
                    <button class="btn-acao verde" @onclick="FinalizarOS">Finalizar serviço</button>
                }
                @if (PodeEntregar)
                {
                    <button class="btn-acao verde" @onclick="EntregarOS">💰 Cobrar e entregar</button>
                }
                @if (PodeCancelar)
                {
                    <button class="btn-acao vermelho" @onclick="CancelarOS">Cancelar</button>
                }
            </div>
        </div>

        <!-- Trilha visual do fluxo -->
        <div class="trilha">
            @foreach (var etapa in trilha)
            {
                <div class="trilha-etapa @TrilhaClass(etapa.status)">
                    <span class="trilha-bola">@etapa.numero</span>
                    <span class="trilha-label">@etapa.label</span>
                </div>
            }
        </div>

        <div class="detalhe-content">
            <div class="detalhe-main">
                <div class="info-card">
                    <h2 class="card-titulo">Informações gerais</h2>
                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Tipo</span>
                            <span class="info-val">@os.Tipo</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Descrição</span>
                            <span class="info-val">@os.Descricao</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Data de abertura</span>
                            <span class="info-val">@os.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Prazo estimado</span>
                            <span class="info-val @(os.PrazoEstimado < DateTime.Now && os.Status != "Finalizada" ? "prazo-vencido" : "")">
                                @os.PrazoEstimado.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Custo do serviço</span>
                            <span class="info-val">
                                @os.CustoServico.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Valor total</span>
                            <span class="info-val destaque">
                                @os.ValorTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                            </span>
                        </div>
                    </div>
                </div>

                <div class="info-card">
                    <div class="card-header-row">
                        <h2 class="card-titulo">Checklist</h2>
                        @if (PodeEditarChecklist)
                        {
                            <button class="btn-mini" @onclick="() => mostrarAdicionarItem = true">
                                + Adicionar item
                            </button>
                        }
                    </div>

                    @if (mostrarAdicionarItem)
                    {
                        <div class="add-item-row">
                            <input class="campo-input-inline"
                                   placeholder="Descrição do item..."
                                   @bind="novoItemDescricao"
                                   @onkeydown="TeclaAdicionarItem" />
                            <button class="btn-mini azul" @onclick="AdicionarItemChecklist">
                                Adicionar
                            </button>
                            <button class="btn-mini" @onclick="() => mostrarAdicionarItem = false">
                                Cancelar
                            </button>
                        </div>
                    }

                    <div class="checklist">
                        @foreach (var item in os.Checklist)
                        {
                            <div class="checklist-item @(item.Status == "Concluido" ? "concluido" : "")">
                                <div class="check-circle @CheckClass(item.Status)"
                                     @onclick="() => AvancarStatusChecklist(item)">
                                    @if (item.Status == "Concluido") { <span>✓</span> }
                                    else if (item.Status == "EmAndamento") { <span>●</span> }
                                </div>
                                <span class="check-descricao">@item.Descricao</span>
                                <span class="check-origem @(item.Origem == "Manual" ? "origem-manual" : "origem-auto")">
                                    @item.Origem
                                </span>
                                <span class="check-status-label @CheckClass(item.Status)">@item.Status</span>
                            </div>
                        }
                        @if (!os.Checklist.Any())
                        {
                            <p class="vazio">Nenhum item de checklist.</p>
                        }
                    </div>
                </div>

                <div class="info-card">
                    <div class="card-header-row">
                        <h2 class="card-titulo">Peças utilizadas</h2>
                        @if (PodeEditarItens)
                        {
                            <button class="btn-mini" @onclick="AbrirModalAdicionarPeca">
                                + Adicionar peça
                            </button>
                        }
                    </div>

                    <div class="itens-lista">
                        @foreach (var item in os.Itens)
                        {
                            var nome = NomeComponente(item.ComponenteId);
                            <div class="item-peca">
                                <span class="item-qtd">@item.Quantidade×</span>
                                <span class="item-nome">@nome</span>
                                <span class="origem-tag @OrigemClass(item.Origem)">@OrigemLabel(item.Origem)</span>
                                @if (item.StatusItem == "AguardandoChegada")
                                {
                                    <span class="status-tag aguardando"
                                          title="Esperando chegar no estoque — atualiza automaticamente">
                                        ⏳ A caminho
                                    </span>
                                }
                                else if (item.StatusItem == "Recebido")
                                {
                                    <span class="status-tag recebido"
                                          title="@(item.DataRecebimento?.ToString("dd/MM HH:mm"))">
                                        ✓ Recebida
                                    </span>
                                }
                                <span class="item-valor">
                                    @item.ValorTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                                </span>
                                @if (PodeEditarItens)
                                {
                                    <button class="btn-mini-icone" title="Remover"
                                            @onclick="() => RemoverPeca(item.Id)">×</button>
                                }
                            </div>
                        }
                        @if (!os.Itens.Any())
                        {
                            <p class="vazio">Nenhuma peça adicionada.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="detalhe-sidebar">
                <div class="progresso-card">
                    <span class="progresso-label">Progresso do checklist</span>
                    @{
                        var total = os.Checklist.Count;
                        var concluidos = os.Checklist.Count(c => c.Status == "Concluido");
                        var pct = total > 0 ? (int)((double)concluidos / total * 100) : 0;
                    }
                    <span class="progresso-pct">@pct%</span>
                    <div class="barra-fundo">
                        <div class="barra-fill" style="width: @pct%"></div>
                    </div>
                    <span class="progresso-detalhe">@concluidos de @total itens concluídos</span>
                </div>
            </div>
        </div>
    </div>
}

@if (modalPecaVisivel)
{
    <div class="modal-overlay" @onclick="() => modalPecaVisivel = false">
        <div class="modal-form" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-titulo">Adicionar peça à OS</span>
                <button class="modal-fechar" @onclick="() => modalPecaVisivel = false">×</button>
            </div>

            <div class="form-campo">
                <label class="campo-label">Componente *</label>
                <select class="campo-input" @bind="pecaComponenteId">
                    <option value="">Selecione...</option>
                    @foreach (var c in componentesDisponiveis)
                    {
                        <option value="@c.Id">@c.Nome (@c.PartNumber)</option>
                    }
                </select>
            </div>

            <div class="form-campo">
                <label class="campo-label">Origem *</label>
                <div class="origem-radios">
                    <label class="origem-radio @(pecaOrigem == "Estoque" ? "ativo" : "")">
                        <input type="radio" name="origem" value="Estoque"
                               checked="@(pecaOrigem == "Estoque")"
                               @onchange='() => pecaOrigem = "Estoque"' />
                        <span class="origem-nome">📦 Estoque</span>
                        <span class="origem-desc">Oficina já tem</span>
                    </label>
                    <label class="origem-radio @(pecaOrigem == "Cliente" ? "ativo" : "")">
                        <input type="radio" name="origem" value="Cliente"
                               checked="@(pecaOrigem == "Cliente")"
                               @onchange='() => pecaOrigem = "Cliente"' />
                        <span class="origem-nome">🧍 Cliente</span>
                        <span class="origem-desc">Cliente trouxe</span>
                    </label>
                    <label class="origem-radio @(pecaOrigem == "Encomenda" ? "ativo" : "")">
                        <input type="radio" name="origem" value="Encomenda"
                               checked="@(pecaOrigem == "Encomenda")"
                               @onchange='() => pecaOrigem = "Encomenda"' />
                        <span class="origem-nome">🚚 Encomenda</span>
                        <span class="origem-desc">A caminho</span>
                    </label>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-campo">
                    <label class="campo-label">Quantidade *</label>
                    <input type="number" min="1" class="campo-input" @bind="pecaQuantidade" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Valor unitário</label>
                    <div class="info-auto">
                        💡 O valor é carregado automaticamente do cadastro do componente.
                    </div>
                </div>
            </div>

            @if (erroPeca is not null)
            {
                <div class="erro-banner">@erroPeca</div>
            }

            <div class="modal-acoes">
                <button class="btn-cancelar" @onclick="() => modalPecaVisivel = false">Cancelar</button>
                <button class="btn-confirmar" @onclick="AdicionarPeca" disabled="@salvandoPeca">
                    @(salvandoPeca ? "Adicionando..." : "Adicionar")
                </button>
            </div>
        </div>
    </div>
}

@if (os is not null)
{
    <div style="max-width:1100px; margin:0 auto; padding: 0 24px 24px;">
        <PainelRequisicoesOS OrdemServicoId="@Id"
                             StatusOrdem="@os.Status"
                             OnAlteracaoEstado="CarregarOS" />
        <PainelAlertasOS OrdemServicoId="@Id"
                         StatusOrdem="@os.Status"
                         OnAlteracaoEstado="CarregarOS" />
        <PainelPagamentoOS OrdemServicoId="@Id" />
    </div>
}

@if (mensagem is not null)
{
    <div class="toast @(erroToast ? "toast-erro" : "toast-ok")">@mensagem</div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private OrdemServicoDTO? os;
    private bool carregando = true;
    private bool mostrarAdicionarItem = false;
    private string novoItemDescricao = string.Empty;
    private string? mensagem;
    private bool erroToast = false;

    // Adicionar peça
    private bool modalPecaVisivel = false;
    private List<ComponenteListaDTO> componentesDisponiveis = new();
    private Guid pecaComponenteId;
    private int pecaQuantidade = 1;
    private string pecaOrigem = "Estoque";
    private string? erroPeca;
    private bool salvandoPeca = false;

    // Auth state
    private bool ehAdmin, ehMecanico, ehRecepcionista;

    private (int numero, string label, string status)[] trilha = Array.Empty<(int, string, string)>();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        ehAdmin = state.User.IsInRole("Admin");
        ehMecanico = state.User.IsInRole("Mecanico");
        ehRecepcionista = state.User.IsInRole("Recepcionista");

        await CarregarOS();
    }

    private async Task CarregarOS()
    {
        carregando = true;
        var resultado = await OrdemService.GetByIdAsync(Id);
        os = resultado.IsSuccess ? resultado.Value : null;
        AtualizarTrilha();
        carregando = false;
    }

    private void AtualizarTrilha()
    {
        if (os is null) return;
        var s = os.Status;
        int atual = s switch
        {
            "Pendente"           => 1,
            "EmAnalise"          => 2,
            "AguardandoCliente"  => 3,
            "Aprovada"           => 4,
            "EmAndamento"        => 5,
            "Finalizada"         => 6,
            "Cancelada"          => 0,
            _                    => 1
        };

        var etapas = new[]
        {
            (1, "Orçamento", ""),
            (2, "Revisão mecânico", ""),
            (3, "Aguardando cliente", ""),
            (4, "Aprovado", ""),
            (5, "Em andamento", ""),
            (6, "Finalizada", "")
        };

        trilha = etapas.Select(e =>
        {
            var status = atual == 0
                ? "cancelada"
                : (e.Item1 < atual ? "ok"
                : e.Item1 == atual ? "atual"
                : "pendente");
            return (e.Item1, e.Item2, status);
        }).ToArray();
    }

    // ========== Permissões ==========

    private bool PodeEnviarRevisao =>
        os?.Status == "Pendente" && (ehAdmin || ehRecepcionista);

    private bool PodeAprovarMecanico =>
        os?.Status == "EmAnalise" && (ehAdmin || ehMecanico);

    private bool PodeMarcarClienteAprovou =>
        os?.Status == "AguardandoCliente" && (ehAdmin || ehRecepcionista);

    private bool PodeIniciar =>
        os?.Status == "Aprovada" && (ehAdmin || ehMecanico);

    private bool PodeFinalizar =>
        os?.Status == "EmAndamento" && (ehAdmin || ehMecanico);

    // Recepção é quem cobra e entrega — mecânico não tem acesso a essa etapa.
    private bool PodeEntregar =>
        os?.Status == "Finalizada" && (ehAdmin || ehRecepcionista);

    private bool PodeCancelar =>
        os is not null
        && os.Status != "Finalizada" && os.Status != "Entregue" && os.Status != "Cancelada"
        && (ehAdmin || ehRecepcionista);

    private bool OsAberta =>
        os is not null
        && os.Status != "Finalizada"
        && os.Status != "Entregue"
        && os.Status != "Cancelada";

    private bool PodeEditarChecklist => OsAberta;
    private bool PodeEditarItens     => OsAberta && (ehAdmin || ehMecanico || ehRecepcionista);

    // ========== Transições ==========

    private async Task EnviarRevisao()
        => await TratarResultado(await OrdemService.EnviarParaRevisaoAsync(Id), "Enviado para revisão.");

    private async Task AprovarMecanico()
        => await TratarResultado(await OrdemService.AprovarPeloMecanicoAsync(Id), "Orçamento aprovado pelo mecânico.");

    private async Task Devolver()
        => await TratarResultado(await OrdemService.DevolverParaAjustesAsync(Id), "Devolvido pra ajustes.");

    private async Task ClienteAprovou()
        => await TratarResultado(await OrdemService.RegistrarAprovacaoDoClienteAsync(Id), "Aprovação do cliente registrada.");

    private async Task IniciarOS()
        => await TratarResultado(await OrdemService.IniciarAsync(Id), "Serviço iniciado.");

    private async Task FinalizarOS()
        => await TratarResultado(await OrdemService.FinalizarAsync(Id), "Serviço finalizado. OS aguardando cobrança/entrega na recepção.");

    private async Task EntregarOS()
        => await TratarResultado(await OrdemService.EntregarAsync(Id), "OS entregue ao cliente.");

    private async Task CancelarOS()
        => await TratarResultado(await OrdemService.CancelarAsync(Id), "OS cancelada.");

    // ========== Itens da OS (peças) ==========

    private async Task AbrirModalAdicionarPeca()
    {
        if (componentesDisponiveis.Count == 0)
        {
            var r = await ComponenteService.GetAllAsync();
            if (r.IsSuccess && r.Value is not null)
                componentesDisponiveis = r.Value.Where(c => c.Ativo).ToList();
        }
        pecaComponenteId = Guid.Empty;
        pecaQuantidade = 1;
        pecaOrigem = "Estoque";
        erroPeca = null;
        modalPecaVisivel = true;
    }

    private async Task AdicionarPeca()
    {
        if (pecaComponenteId == Guid.Empty) { erroPeca = "Selecione um componente."; return; }
        if (pecaQuantidade < 1)             { erroPeca = "Quantidade inválida.";   return; }

        var statusAntes = os?.Status;

        salvandoPeca = true;
        var r = await OrdemService.AdicionarItemAsync(new AdicionarItemOrdemServicoDTO
        {
            OrdemServicoId = Id,
            ComponenteId = pecaComponenteId,
            Quantidade = pecaQuantidade,
            ValorUnitario = 0, // ignorado pelo service — valor vem sempre do componente
            Origem = pecaOrigem
        });
        salvandoPeca = false;

        if (r.IsSuccess)
        {
            modalPecaVisivel = false;
            await CarregarOS();
            // Se a OS estava EmAndamento, o service pausa automaticamente e cria alerta.
            var avisoExtra = statusAntes == "EmAndamento"
                ? " OS pausada — recepção será notificada para o cliente reaprovar."
                : "";
            await MostrarMensagem("Peça adicionada." + avisoExtra, false);
        }
        else
        {
            erroPeca = r.Error;
        }
    }

    private async Task RemoverPeca(Guid itemId)
    {
        var r = await OrdemService.RemoverItemAsync(Id, itemId);
        if (r.IsSuccess) await CarregarOS();
        else await MostrarMensagem(r.Error ?? "Erro ao remover.", true);
    }

    private string NomeComponente(Guid id)
        => componentesDisponiveis.FirstOrDefault(c => c.Id == id)?.Nome ?? id.ToString()[..8];

    // ========== Checklist ==========

    private async Task AdicionarItemChecklist()
    {
        if (string.IsNullOrWhiteSpace(novoItemDescricao)) return;

        var resultado = await OrdemService.AdicionarItemChecklistAsync(
            new AdicionarChecklistItemDTO
            {
                OrdemServicoId = Id,
                Descricao = novoItemDescricao
            });

        if (resultado.IsSuccess)
        {
            novoItemDescricao = string.Empty;
            mostrarAdicionarItem = false;
            await CarregarOS();
        }
        else
        {
            await MostrarMensagem(resultado.Error ?? "Erro.", erro: true);
        }
    }

    private async Task AvancarStatusChecklist(ChecklistItemDTO item)
    {
        if (item.Status == "Concluido") return;
        if (!OsAberta) return;

        var novoStatus = item.Status == "Pendente" ? "EmAndamento" : "Concluido";
        var resultado = await OrdemService.AtualizarStatusChecklistAsync(
            new AtualizarStatusChecklistDTO
            {
                OrdemServicoId = Id,
                ItemId = item.Id,
                NovoStatus = novoStatus
            });

        if (resultado.IsSuccess) await CarregarOS();
    }

    private async Task TeclaAdicionarItem(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AdicionarItemChecklist();
        if (e.Key == "Escape") mostrarAdicionarItem = false;
    }

    private async Task TratarResultado(
        CarStoreManager.Application.Common.Result resultado, string msg)
    {
        if (resultado.IsSuccess)
        {
            await MostrarMensagem(msg, erro: false);
            await CarregarOS();
        }
        else
        {
            await MostrarMensagem(resultado.Error ?? "Erro.", erro: true);
        }
    }

    private async Task MostrarMensagem(string msg, bool erro)
    {
        mensagem = msg;
        erroToast = erro;
        StateHasChanged();
        await Task.Delay(3000);
        mensagem = null;
        StateHasChanged();
    }

    // ========== UI helpers ==========

    private string StatusLabel(string s) => s switch
    {
        "Pendente"          => "Pendente",
        "EmAnalise"         => "Em revisão (mecânico)",
        "AguardandoCliente" => "Aguardando cliente",
        "Aprovada"          => "Aprovada",
        "EmAndamento"       => "Em andamento",
        "Finalizada"        => "Finalizada",
        "Cancelada"         => "Cancelada",
        _                   => s
    };

    private string StatusClass(string status) => status switch
    {
        "Pendente"          => "status-pendente",
        "EmAnalise"         => "status-analise",
        "AguardandoCliente" => "status-aguardando",
        "Aprovada"          => "status-aprovada",
        "EmAndamento"       => "status-andamento",
        "Finalizada"        => "status-finalizada",
        "Cancelada"         => "status-cancelada",
        _                   => "status-pendente"
    };

    private string CheckClass(string status) => status switch
    {
        "Concluido"   => "check-concluido",
        "EmAndamento" => "check-andamento",
        _             => "check-pendente"
    };

    private string TrilhaClass(string status) => status switch
    {
        "ok"        => "trilha-ok",
        "atual"     => "trilha-atual",
        "cancelada" => "trilha-cancelada",
        _           => "trilha-pendente"
    };

    private string OrigemLabel(string origem) => origem switch
    {
        "Estoque"   => "📦 Estoque",
        "Cliente"   => "🧍 Cliente",
        "Encomenda" => "🚚 Encomenda",
        _           => origem
    };

    private string OrigemClass(string origem) => origem switch
    {
        "Cliente"   => "origem-cliente",
        "Encomenda" => "origem-encomenda",
        _           => "origem-estoque"
    };
}

<style>
    .detalhe-page { max-width: 1100px; margin: 0 auto; padding: 24px; }

    .detalhe-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .btn-voltar { background: none; border: none; color: #888; font-size: 14px; cursor: pointer; }
    .btn-voltar:hover { color: #1a1a1a; }

    .header-info { display: flex; align-items: center; gap: 12px; flex: 1; }

    .os-numero-grande {
        font-size: 20px;
        font-weight: 600;
        font-family: monospace;
        color: #3b82f6;
    }

    .header-acoes { display: flex; gap: 6px; margin-left: auto; flex-wrap: wrap; }

    .btn-acao {
        border: none;
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
