@page "/oficina/componentes"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Mecanico")]

@namespace CarStoreManager.Web.Components.Pages

@inject IComponenteService ComponenteService
@inject IEstoqueService EstoqueService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Application.DTOs.Oficina.Componente
@using Microsoft.AspNetCore.Components.Authorization

@using Microsoft.AspNetCore.Components.Web

<div class="comp-page">
    <div class="page-header">
        <div>
            <h1 class="page-titulo">Componentes</h1>
            <p class="page-sub">Cadastro de peças e controle de estoque</p>
        </div>
        @if (ehAdmin)
        {
            <button class="btn-novo" @onclick="AbrirModalNovo">+ Novo componente</button>
        }
    </div>

    @if (estoquesBaixo.Any())
    {
        <div class="alerta-estoque">
            <span class="alerta-icone">⚠</span>
            <span>@estoquesBaixo.Count peça(s) com estoque abaixo do mínimo</span>
            <button class="alerta-btn" @onclick='() => FiltrarPor("EstoqueBaixo")'>
                Ver peças
            </button>
        </div>
    }

    <div class="filtros-row">
        <div class="filtros-status">
            <button class="@FiltroClass("Todos")"
                    @onclick='() => FiltrarPor("Todos")'>Todos</button>
            <button class="@FiltroClass("EstoqueBaixo")"
                    @onclick='() => FiltrarPor("EstoqueBaixo")'>Estoque baixo</button>
            @foreach (var s in todosSistemas)
            {
                <button class="@FiltroClass(s)"
                        @onclick="() => FiltrarPor(s)">@s</button>
            }
        </div>
        <input class="busca-input"
               placeholder="Buscar componente..."
               @bind="termoBusca"
               @bind:event="oninput" />
    </div>

    @if (carregando)
    {
        <div class="loading">Carregando componentes...</div>
    }
    else if (!componentesFiltrados.Any())
    {
        <div class="vazio">Nenhum componente encontrado.</div>
    }
    else
    {
        <div class="comp-tabela">
            <div class="tabela-header">
                <span>Nome</span>
                <span>Part Number</span>
                <span>Sistema</span>
                <span>Estoque</span>
                <span>Mínimo</span>
                @if (ehAdmin)
                {
                    <span>Ações</span>
                }
            </div>

            @foreach (var c in componentesFiltrados)
            {
                var est = ObterEstoque(c.Id);
                <div class="tabela-row @(est is null || est.SemEstoque ? "sem-estoque" : "")">
                    <span class="comp-nome clicavel" @onclick="() => AbrirModalDetalhe(c)">@c.Nome</span>
                    <span class="comp-pn">@c.PartNumber</span>
                    <span class="comp-sistema">@c.Sistema</span>
                    <span class="comp-qtd @EstoqueClass(est)">
                        @(est?.QuantidadeAtual ?? 0)
                    </span>
                    <span class="comp-min">@(est?.QuantidadeMinima ?? 0)</span>
                    @if (ehAdmin)
                    {
                        <div class="comp-acoes">
                            <button class="btn-mini verde"
                                    @onclick="() => AbrirModalEntrada(c)">
                                + Entrada
                            </button>
                            <button class="btn-mini"
                                    @onclick="() => AbrirModalMinimo(c, est)">
                                Mínimo
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@if (modalNovoVisivel)
{
    <div class="modal-overlay" @onclick="() => modalNovoVisivel = false">
        <div class="modal-form" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-titulo">Novo componente</span>
                <button class="modal-fechar"
                        @onclick="() => modalNovoVisivel = false">×</button>
            </div>

            <div class="form-grid">
                <div class="form-campo span-2">
                    <label class="campo-label">Nome *</label>
                    <input class="campo-input" @bind="formComp.Nome" />
                </div>
                <div class="form-campo span-2">
                    <label class="campo-label">Descrição</label>
                    <input class="campo-input" @bind="formComp.Descricao" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">SKU interno *</label>
                    <input class="campo-input" @bind="formComp.SKUInterno" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Marca *</label>
                    <input class="campo-input" @bind="formComp.MarcaFabricante" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Part Number *</label>
                    <input class="campo-input" @bind="formComp.PartNumber" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Código OEM</label>
                    <input class="campo-input" @bind="formComp.CodigoOEM" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Sistema *</label>
                    <select class="campo-input" @bind="formComp.Sistema">
                        @foreach (var s in todosSistemas)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="form-campo">
                    <label class="campo-label">NCM (8 dígitos) *</label>
                    <input class="campo-input" @bind="formComp.NCM" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">CEST (7 dígitos)</label>
                    <input class="campo-input" @bind="formComp.CEST" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Categoria *</label>
                    <input class="campo-input" @bind="formComp.Categoria" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Unidade *</label>
                    <input class="campo-input" @bind="formComp.Unidade" placeholder="UN, KG, L..." />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Peso (kg)</label>
                    <input type="number" step="0.001" class="campo-input" @bind="formComp.Peso" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Garantia (dias)</label>
                    <input type="number" class="campo-input" @bind="formComp.GarantiaDias" />
                </div>
            </div>

            @if (erroForm is not null)
            {
                <div class="erro-banner">@erroForm</div>
            }

            <div class="modal-acoes">
                <button class="btn-cancelar"
                        @onclick="() => modalNovoVisivel = false">Cancelar</button>
                <button class="btn-confirmar"
                        @onclick="SalvarComponente"
                        disabled="@salvando">
                    @(salvando ? "Salvando..." : "Cadastrar")
                </button>
            </div>
        </div>
    </div>
}

@if (modalEntradaVisivel)
{
    <div class="modal-overlay" @onclick="() => modalEntradaVisivel = false">
        <div class="modal-form pequeno" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-titulo">Entrada de estoque</span>
                <button class="modal-fechar"
                        @onclick="() => modalEntradaVisivel = false">×</button>
            </div>
            <p class="modal-sub">@componenteSelecionado?.Nome</p>
            <p class="modal-sub">
                Estoque atual: @(ObterEstoque(componenteSelecionado?.Id ?? Guid.Empty)?.QuantidadeAtual ?? 0) unidades
            </p>

            <div class="form-campo" style="margin-top: 16px;">
                <label class="campo-label">Quantidade a adicionar</label>
                <input type="number" class="campo-input"
                       @bind="quantidadeEntrada"
                       min="1" />
            </div>

            @if (erroForm is not null)
            {
                <div class="erro-banner">@erroForm</div>
            }

            <div class="modal-acoes">
                <button class="btn-cancelar"
                        @onclick="() => modalEntradaVisivel = false">Cancelar</button>
                <button class="btn-confirmar verde"
                        @onclick="ConfirmarEntrada"
                        disabled="@salvando">
                    @(salvando ? "Salvando..." : "Confirmar entrada")
                </button>
            </div>
        </div>
    </div>
}

@if (modalMinimoVisivel)
{
    <div class="modal-overlay" @onclick="() => modalMinimoVisivel = false">
        <div class="modal-form pequeno" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-titulo">Estoque mínimo</span>
                <button class="modal-fechar"
                        @onclick="() => modalMinimoVisivel = false">×</button>
            </div>
            <p class="modal-sub">@componenteSelecionado?.Nome</p>

            <div class="form-campo" style="margin-top: 16px;">
                <label class="campo-label">Quantidade mínima</label>
                <input type="number" class="campo-input"
                       @bind="quantidadeMinima"
                       min="0" />
            </div>

            @if (erroForm is not null)
            {
                <div class="erro-banner">@erroForm</div>
            }

            <div class="modal-acoes">
                <button class="btn-cancelar"
                        @onclick="() => modalMinimoVisivel = false">Cancelar</button>
                <button class="btn-confirmar"
                        @onclick="ConfirmarMinimo"
                        disabled="@salvando">
                    @(salvando ? "Salvando..." : "Salvar")
                </button>
            </div>
        </div>
    </div>
}

@if (modalDetalheVisivel && componenteDetalhe is not null)
{
    <div class="modal-overlay" @onclick="() => modalDetalheVisivel = false">
        <div class="modal-form" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-titulo">@componenteDetalhe.Nome</span>
                <button class="modal-fechar"
                        @onclick="() => modalDetalheVisivel = false">×</button>
            </div>

            <div class="detalhe-grid">
                <div class="detalhe-item">
                    <span class="detalhe-label">SKU interno</span>
                    <span class="detalhe-val">@componenteDetalhe.SKUInterno</span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">Part Number</span>
                    <span class="detalhe-val mono">@componenteDetalhe.PartNumber</span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">Código OEM</span>
                    <span class="detalhe-val mono">
                        @(string.IsNullOrWhiteSpace(componenteDetalheCompleto?.CodigoOEM) ? "—" : componenteDetalheCompleto.CodigoOEM)
                    </span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">Marca</span>
                    <span class="detalhe-val">@componenteDetalhe.MarcaFabricante</span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">Categoria</span>
                    <span class="detalhe-val">@componenteDetalhe.Categoria</span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">NCM</span>
                    <span class="detalhe-val mono">@(componenteDetalheCompleto?.NCM ?? "—")</span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">CEST</span>
                    <span class="detalhe-val mono">
                        @(string.IsNullOrWhiteSpace(componenteDetalheCompleto?.CEST) ? "—" : componenteDetalheCompleto.CEST)
                    </span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">Código de barras</span>
                    <span class="detalhe-val mono">
                        @(string.IsNullOrWhiteSpace(componenteDetalheCompleto?.CodigoBarras) ? "—" : componenteDetalheCompleto.CodigoBarras)
                    </span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">Peso (kg)</span>
                    <span class="detalhe-val">@(componenteDetalheCompleto?.Peso.ToString("F3") ?? "—")</span>
                </div>
                <div class="detalhe-item">
                    <span class="detalhe-label">Garantia</span>
                    <span class="detalhe-val">@(componenteDetalheCompleto?.GarantiaDias ?? 0) dias</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(componenteDetalheCompleto?.Descricao))
            {
                <div class="detalhe-descricao">
                    <span class="detalhe-label">Descrição</span>
                    <p>@componenteDetalheCompleto.Descricao</p>
                </div>
            }

            <div class="detalhe-acoes">
                <button class="btn-confirmar" @onclick="BuscarEquivalentes" disabled="@buscandoEquivalentes">
                    @(buscandoEquivalentes ? "Buscando..." : "🔎 Buscar equivalentes (OEM)")
                </button>
            </div>

            @if (equivalentesCarregados)
            {
                <div class="equivalentes-secao">
                    <h3 class="secao-mini">Equivalentes encontrados</h3>
                    @if (!equivalentes.Any())
                    {
                        <p class="vazio">
                            Nenhuma peça equivalente encontrada para o OEM
                            <code>@(componenteDetalheCompleto?.CodigoOEM ?? "—")</code>.
                        </p>
                    }
                    else
                    {
                        <ul class="equivalentes-lista">
                            @foreach (var e in equivalentes)
                            {
                                var estE = ObterEstoque(e.Id);
                                <li class="equiv-item">
                                    <div class="equiv-info">
                                        <span class="equiv-nome">@e.Nome</span>
                                        <span class="equiv-marca">@e.MarcaFabricante · @e.PartNumber</span>
                                    </div>
                                    <span class="equiv-estoque @EstoqueClass(estE)">
                                        @(estE?.QuantidadeAtual ?? 0) un.
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private List<ComponenteListaDTO> componentes = new();
    private List<ComponenteListaDTO> componentesFiltrados = new();
    private List<EstoqueComponenteDTO> estoques = new();
    private List<EstoqueComponenteDTO> estoquesBaixo = new();
    private string filtroAtivo = "Todos";
    private string termoBusca = string.Empty;
    private bool carregando = true;
    private bool ehAdmin = false;
    private bool modalNovoVisivel = false;
    private bool modalEntradaVisivel = false;
    private bool modalMinimoVisivel = false;
    private bool modalDetalheVisivel = false;
    private bool salvando = false;

    // Detalhe + equivalentes
    private ComponenteListaDTO? componenteDetalhe;
    private ComponenteDTO? componenteDetalheCompleto;
    private List<ComponenteListaDTO> equivalentes = new();
    private bool equivalentesCarregados = false;
    private bool buscandoEquivalentes = false;
    private string? erroForm;
    private ComponenteListaDTO? componenteSelecionado;
    private int quantidadeEntrada = 1;
    private int quantidadeMinima = 0;

    private CriarComponenteDTO formComp = NovoForm();

    private readonly List<string> todosSistemas = new()
    {
        "Motor", "Suspensao", "Direcao", "Freios", "Eletrica",
        "Lataria", "Transmissão", "Arrefecimento", "Escapamento",
        "Acessorios", "Interior"
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        ehAdmin = state.User.IsInRole("Admin");

        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true;

        var resultado = await ComponenteService.GetAllAsync();
        componentes = resultado.IsSuccess
            ? resultado.Value?.ToList() ?? new()
            : new();

        var rEstoque = await EstoqueService.ListarAsync();
        estoques = rEstoque.IsSuccess
            ? rEstoque.Value?.ToList() ?? new()
            : new();

        estoquesBaixo = estoques.Where(e => e.EstoqueBaixo).ToList();

        AplicarFiltro();
        carregando = false;
    }

    private EstoqueComponenteDTO? ObterEstoque(Guid componenteId)
        => estoques.FirstOrDefault(e => e.ComponenteId == componenteId);

    private void FiltrarPor(string filtro)
    {
        filtroAtivo = filtro;
        AplicarFiltro();
    }

    private void AplicarFiltro()
    {
        var base_ = filtroAtivo switch
        {
            "EstoqueBaixo" => componentes
                .Where(c => estoquesBaixo.Any(e => e.ComponenteId == c.Id)).ToList(),
            "Todos" => componentes.ToList(),
            _ => componentes.Where(c => c.Sistema == filtroAtivo).ToList()
        };

        componentesFiltrados = string.IsNullOrWhiteSpace(termoBusca)
            ? base_
            : base_.Where(c => c.Nome.Contains(
                termoBusca, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void AbrirModalNovo()
    {
        formComp = NovoForm();
        erroForm = null;
        modalNovoVisivel = true;
    }

    private void AbrirModalEntrada(ComponenteListaDTO c)
    {
        componenteSelecionado = c;
        quantidadeEntrada = 1;
        erroForm = null;
        modalEntradaVisivel = true;
    }

    private void AbrirModalMinimo(ComponenteListaDTO c, EstoqueComponenteDTO? est)
    {
        componenteSelecionado = c;
        quantidadeMinima = est?.QuantidadeMinima ?? 0;
        erroForm = null;
        modalMinimoVisivel = true;
    }

    private async Task AbrirModalDetalhe(ComponenteListaDTO c)
    {
        componenteDetalhe = c;
        componenteDetalheCompleto = null;
        equivalentes.Clear();
        equivalentesCarregados = false;
        buscandoEquivalentes = false;
        modalDetalheVisivel = true;

        // Carrega o DTO completo (com OEM, NCM, descrição etc)
        var r = await ComponenteService.GetByIdAsync(c.Id);
        if (r.IsSuccess) componenteDetalheCompleto = r.Value;
    }

    private async Task BuscarEquivalentes()
    {
        if (componenteDetalhe is null) return;
        buscandoEquivalentes = true;
        equivalentes.Clear();

        var r = await ComponenteService.ObterEquivalentesAsync(componenteDetalhe.Id);
        if (r.IsSuccess) equivalentes = r.Value ?? new();

        buscandoEquivalentes = false;
        equivalentesCarregados = true;
    }

    private async Task SalvarComponente()
    {
        salvando = true;
        erroForm = null;

        try
        {
            var r = await ComponenteService.AddAsync(formComp);
            if (r.IsSuccess)
            {
                modalNovoVisivel = false;
                await CarregarDados();
            }
            else
            {
                erroForm = r.Error;
            }
        }
        catch (Exception ex) { erroForm = $"Erro ao salvar: {ex.Message}"; }
        finally { salvando = false; }
    }

    private async Task ConfirmarEntrada()
    {
        if (quantidadeEntrada <= 0 || componenteSelecionado is null) return;

        salvando = true;
        erroForm = null;

        var resultado = await EstoqueService.EntradaAsync(
            componenteSelecionado.Id, quantidadeEntrada);

        if (resultado.IsSuccess)
        {
            modalEntradaVisivel = false;
            await CarregarDados();
        }
        else
        {
            erroForm = resultado.Error;
        }

        salvando = false;
    }

    private async Task ConfirmarMinimo()
    {
        if (quantidadeMinima < 0 || componenteSelecionado is null) return;

        salvando = true;
        erroForm = null;

        var resultado = await EstoqueService.CriarOuAtualizarMinimoAsync(
            componenteSelecionado.Id, quantidadeMinima);

        if (resultado.IsSuccess)
        {
            modalMinimoVisivel = false;
            await CarregarDados();
        }
        else
        {
            erroForm = resultado.Error;
        }

        salvando = false;
    }

    private string FiltroClass(string f) =>
        f == filtroAtivo ? "filtro-os ativo" : "filtro-os";

    private string EstoqueClass(EstoqueComponenteDTO? est)
    {
        if (est is null || est.SemEstoque) return "qtd-zero";
        if (est.EstoqueBaixo) return "qtd-baixo";
        return "qtd-ok";
    }

    private static CriarComponenteDTO NovoForm() => new()
    {
        Sistema = "Motor",
        Unidade = "UN"
    };
}

<style>
    .comp-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 24px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
    }

    .page-titulo { font-size: 24px; font-weight: 500; margin-bottom: 4px; }
    .page-sub { font-size: 14px; color: #888; }

    .btn-novo {
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-novo:hover { background: #1d4ed8; }

    .alerta-estoque {
        background: #fff7ed;
        border: 0.5px solid #fed7aa;
        border-radius: 10px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        font-size: 13px;
        color: #9a3412;
    }

    .alerta-icone { font-size: 16px; }

    .alerta-btn {
        margin-left: auto;
        background: #ea580c;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 12px;
        cursor: pointer;
    }

    .filtros-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .filtros-status {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .filtro-os {
        background: #f4f4f4;
        border: 0.5px solid #e0e0e0;
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 12px;
        color: #555;
        cursor: pointer;
    }

    .filtro-os.ativo {
        background: #1a1a1a;
        border-color: #1a1a1a;
        color: #fff;
    }

    .busca-input {
        border: 0.5px solid #ccc;
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 13px;
        outline: none;
        min-width: 200px;
    }

    .busca-input:focus { border-color: #3b82f6; }

    .comp-tabela {
        background: #fff;
        border: 0.5px solid #e0e0e0;
        border-radius: 12px;
        overflow: hidden;
    }

    .tabela-header {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 80px 80px 160px;
        padding: 10px 16px;
        background: #f4f4f4;
        font-size: 11px;
        color: #888;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .tabela-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 80px 80px 160px;
        padding: 12px 16px;
        border-top: 0.5px solid #f0f0f0;
        align-items: center;
        font-size: 13px;
        transition: background 0.15s;
    }

    .tabela-row:hover { background: #fafafa; }
    .sem-estoque { opacity: 0.6; }

    .comp-nome { font-weight: 500; }
    .comp-nome.clicavel { cursor: pointer; color: #2563eb; }
    .comp-nome.clicavel:hover { text-decoration: underline; }
