@page "/oficina/os/nova"
@rendermode InteractiveServer
@namespace CarStoreManager.Web.Components.Pages

@inject IOrdemServicoService OrdemService
@inject IMecanicoService MecanicoService
@inject NavigationManager Navigation

@using CarStoreManager.Application.DTOs.Oficina.OrdemServico
@using CarStoreManager.Application.DTOs.Oficina.Mecanico
@using CarStoreManager.Application.Interfaces
@using CarStoreManager.Web.Components.Shared

<PageTitle>Nova Ordem de Serviço</PageTitle>

<div class="form-page">
    <div class="page-header">
        <button class="btn-voltar" @onclick='() => Navigation.NavigateTo("/oficina")'>
            ← Voltar
        </button>
        <h1 class="page-titulo">Nova Ordem de Serviço</h1>
    </div>

    <EditForm Model="@form" OnValidSubmit="Salvar">
        <DataAnnotationsValidator />

        <ClientSelector @bind-Value="form.ClienteId" />
        <VeiculoClienteCadastro @bind-Value="form.VeiculoClienteId" ClienteId="form.ClienteId" />

        <div class="form-card">
            <h2 class="secao-titulo">Mecânico e Serviços</h2>
            <div class="form-grid">
                <div class="form-campo span-2">
                    <label class="campo-label">Mecânico responsável *</label>
                    <select class="campo-input" @bind="form.MecanicoId">
                        <option value="">Selecione um mecânico...</option>
                        @foreach (var m in mecanicos)
                        {
                            <option value="@m.Id">@m.Nome (@m.Especialidade)</option>
                        }
                    </select>
                </div>
                <div class="form-campo span-2">
                    <label class="campo-label">Descrição do serviço *</label>
                    <textarea class="campo-input" rows="3" @bind="form.Descricao"
                              placeholder="Ex: Troca de óleo e revisão dos freios"></textarea>
                </div>
                <div class="form-campo">
                    <label class="campo-label">Valor total estimado (R$)</label>
                    <input type="number" step="0.01" class="campo-input" @bind="form.CustoServico" />
                </div>
                <div class="form-campo">
                    <label class="campo-label">Data prevista</label>
                    <input type="date" class="campo-input" @bind="form.PrazoEstimado" />
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="erro-banner">@erro</div>
        }
        @if (sucesso)
        {
            <div class="sucesso-banner">Ordem de serviço criada com sucesso!</div>
        }

        <div class="form-acoes">
            <button type="button" class="btn-cancelar"
                    @onclick='() => Navigation.NavigateTo("/oficina")'>
                Cancelar
            </button>
            <button type="submit" class="btn-salvar" disabled="@salvando">
                @(salvando ? "Salvando..." : "Criar Ordem")
            </button>
        </div>
    </EditForm>
</div>

@code {
    private CriarOrdemServicoDTO form = new()
    {
        PrazoEstimado = DateTime.Today.AddDays(3)
    };

    private List<MecanicoListaDTO> mecanicos = new();
    private bool salvando = false;
    private bool sucesso = false;
    private string? erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var mecanicosResult = await MecanicoService.GetAllAsync();
            if (mecanicosResult.IsSuccess)
                mecanicos = mecanicosResult.Value?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar mecânicos: {ex.Message}";
        }
    }

    private async Task Salvar()
    {
        if (form.ClienteId == Guid.Empty || form.VeiculoClienteId == Guid.Empty ||
            form.MecanicoId == Guid.Empty || string.IsNullOrWhiteSpace(form.Descricao))
        {
            erro = "Preencha todos os campos obrigatórios.";
            return;
        }

        salvando = true;
        erro = null;
        sucesso = false;

        try
        {
            var resultado = await OrdemService.AddAsync(form);
            if (resultado.IsSuccess)
            {
                sucesso = true;
                await Task.Delay(1200);
                Navigation.NavigateTo($"/oficina/ordemservico/{resultado.Value}");
            }
            else
            {
                erro = resultado.Error;
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro ao criar ordem de serviço: {ex.Message}";
        }
        finally
        {
            salvando = false;
        }
    }
}

<style>
    .form-page { max-width: 800px; margin: 0 auto; padding: 24px; }
    .page-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
    .btn-voltar { background: none; border: none; color: #888; font-size: 14px; cursor: pointer; }
    .page-titulo { font-size: 22px; font-weight: 500; }
    .form-card { background: #fff; border: 0.5px solid #e0e0e0; border-radius: 12px; padding: 20px; margin-bottom: 16px; }
    .secao-titulo { font-size: 14px; font-weight: 500; color: #1a1a1a; margin-bottom: 16px; border-bottom: 0.5px solid #eee; padding-bottom: 10px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-campo { display: flex; flex-direction: column; gap: 6px; }
    .span-2 { grid-column: span 2; }
    .campo-label { font-size: 12px; color: #555; font-weight: 500; }
    .campo-input { border: 0.5px solid #ccc; border-radius: 8px; padding: 9px 12px; font-size: 14px; outline: none; width: 100%; }
    .erro-banner { background: #fff5f5; border: 0.5px solid #fca5a5; border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #e02020; margin-bottom: 16px; }
    .sucesso-banner { background: #f0fdf4; border: 0.5px solid #86efac; border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #166534; margin-bottom: 16px; }
    .form-acoes { display: flex; gap: 10px; justify-content: flex-end; margin-top: 8px; }
    .btn-cancelar { background: #fff; border: 0.5px solid #ccc; border-radius: 8px; padding: 10px 20px; font-size: 14px; cursor: pointer; color: #444; }
    .btn-salvar { background: #e02020; color: #fff; border: none; border-radius: 8px; padding: 10px 24px; font-size: 14px; font-weight: 500; cursor: pointer; }
    .btn-salvar:disabled { opacity: 0.6; cursor: not-allowed; }
</style>