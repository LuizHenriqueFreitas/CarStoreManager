@page "/oficina"

<div class="layout">

    <!-- TOPO -->
    <div class="topo">
        <SeletorWorkspace />

        <div class="usuario">
            Usuário logado
        </div>
    </div>

    <!-- CONTEÚDO -->
    <div class="conteudo">

        <!-- 🔴 LADO ESQUERDO -->
        <div class="painel-esquerdo">

            <!-- CABEÇALHO -->
            <div class="header-servico">
                <div class="foto">foto carro</div>
                <div class="dados">dados do serviço</div>
                <div class="status">status e prazo</div>
            </div>

            <!-- LISTA DE SERVIÇOS -->
            <div class="lista-servicos">
                serviços de reparo em andamento
            </div>

        </div>

        <!-- 🔵 LADO DIREITO -->
        <div class="painel-direito">

            <!-- INFO SUPERIOR -->
            <div class="info-superior">
                <div class="foto-mecanico">foto mecânico</div>
                <div class="dados-servico">
                    dados relacionados / status de disponibilidade
                </div>
            </div>

            <!-- PARTE INFERIOR -->
            <div class="info-inferior">

                <div class="estoque">
                    gerenciamento do estoque
                </div>

                <div class="gestao">
                    gerenciamento de prazos, serviços e mecânicos
                </div>

            </div>

        </div>

    </div>

    <!-- RODAPÉ -->
    <div class="rodape">
        <div></div>
        <button class="btn-proposta">Gerar proposta de reparo</button>
    </div>

</div>