@namespace CarStoreManager.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using CarStoreManager.Application.Interfaces
@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS 

<nav class="navbar">
    <a href="/" class="navbar-logo">AUTOSTORE</a>

    <div class="navbar-links">
        <NavLink href="/concessionaria" class="nav-link" ActiveClass="nav-link-active">
            Concessionária
        </NavLink>
        <NavLink href="/oficina" class="nav-link" ActiveClass="nav-link-active">
            Oficina
        </NavLink>
        <NavLink href="/dashboard" class="nav-link" ActiveClass="nav-link-active">
            Relatórios
        </NavLink>
    </div>

    <div class="navbar-user" @onclick="ToggleDropdown">
        <div class="navbar-avatar">
            @(NomeUsuario.Length > 0 ? NomeUsuario[0].ToString().ToUpper() : "?")
        </div>
        <span>@NomeUsuario</span>
        <span class="dropdown-seta">▾</span>

        @if (mostrarDropdown)
        {
            <div class="dropdown-menu" @onclick:stopPropagation>
                <div class="dropdown-header">@NomeUsuario</div>
                <button class="dropdown-item" @onclick="IrParaConfiguracoes">
                    Configurações
                </button>
                <button class="dropdown-item" @onclick="Logout">
                    Sair
                </button>
            </div>
        }
    </div>
</nav>

@code {
    [Parameter] public string NomeUsuario { get; set; } = "Usuário";

    private bool mostrarDropdown = false;

    private void ToggleDropdown()
    {
        mostrarDropdown = !mostrarDropdown;
    }

    private void IrParaConfiguracoes()
    {
        mostrarDropdown = false;
        Navigation.NavigateTo("/configuracoes");
    }

    private async Task Logout()
    {
        mostrarDropdown = false;
        try
        {
            // Remove o token JWT do localStorage (onde provavelmente está armazenado)
            await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
            
            // Opcional: chama o backend para invalidar (já implementado)
            // var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            // var claim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            // if (claim != null) await AuthService.LogoutAsync(Guid.Parse(claim.Value));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao limpar token: {ex.Message}");
        }
        
        // Redireciona para login com recarga completa para limpar todo o estado do circuito
        Navigation.NavigateTo("/login?logout=true", forceLoad: true);
    }
}

