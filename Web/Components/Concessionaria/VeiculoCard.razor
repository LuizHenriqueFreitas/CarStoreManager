@namespace CarStoreManager.Web.Components.Concessionaria

@using CarStoreManager.Application.DTOs.Concessionaria.VeiculoVenda

<div class="vcard" @onclick="OnClick">
    <div class="vcard-img">
        @if (Veiculo.FotoPrincipal is not null)
        {
            <img src="@Veiculo.FotoPrincipal" alt="@Veiculo.Marca @Veiculo.Modelo" />
        }
        else
        {
            <div class="vcard-no-foto">Sem foto</div>
        }
        <span class="badge @BadgeClass">@Veiculo.Disponibilidade</span>
    </div>

    <div class="vcard-body">
        <div class="vcard-nome">@Veiculo.Marca @Veiculo.Modelo</div>
        <div class="vcard-sub">@Veiculo.Ano · @Veiculo.Combustivel · @Veiculo.Disponibilidade</div>
        <div class="vcard-preco">@Veiculo.Valor.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</div>
        <div class="vcard-tags">
            <span class="vtag">@Veiculo.Ano.ToString("N0") km</span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public VeiculoVendaListaDTO Veiculo { get; set; } = null!;
    [Parameter] public EventCallback OnClick { get; set; }

    private string BadgeClass => Veiculo.Disponibilidade switch
    {
        "Disponivel" => "badge badge-disponivel",
        "Vendido"    => "badge badge-vendido",
        _            => "badge badge-reservado"
    };
}

<style>
    .vcard {
        background: #fff;
        border-radius: 10px;
        border: 0.5px solid #e0e0e0;
        overflow: hidden;
        cursor: pointer;
        transition: border-color 0.2s, transform 0.15s;
    }

    .vcard:hover {
        border-color: #e02020;
        transform: translateY(-2px);
    }

    .vcard-img {
        position: relative;
        height: 160px;
        background: #1a1a1a;
        overflow: hidden;
    }

    .vcard-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .vcard-no-foto {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #555;
        font-size: 13px;
    }

    .vcard-img .badge {
        position: absolute;
        top: 10px;
        left: 10px;
    }

    .vcard-body { padding: 12px 14px; }

    .vcard-nome {
        font-size: 15px;
        font-weight: 500;
        color: #1a1a1a;
        margin-bottom: 2px;
    }

    .vcard-sub {
        font-size: 12px;
        color: #888;
        margin-bottom: 8px;
    }

    .vcard-preco {
        font-size: 18px;
        font-weight: 600;
        color: #e02020;
        margin-bottom: 8px;
    }

    .vcard-tags { display: flex; gap: 6px; flex-wrap: wrap; }

    .vtag {
        background: #f4f4f4;
        border: 0.5px solid #e0e0e0;
        border-radius: 4px;
        font-size: 11px;
        color: #555;
        padding: 2px 8px;
    }
</style>